{
  "private": true,
  "name": "sorena-visa-platform",
  "description": "Workspace-root scripts. Backend and frontend are independent npm projects under their respective folders; this file exists only to host cross-cutting dev-tooling scripts.",
  "scripts": {
    "kill-stale": "node backend/scripts/kill-port.js 3000 3001",
    "dev:up": "pm2 start ecosystem.config.js",
    "dev:down": "pm2 stop ecosystem.config.js",
    "dev:restart": "pm2 restart ecosystem.config.js",
    "dev:status": "pm2 status",
    "dev:logs": "pm2 logs",
    "dev:logs:backend": "pm2 logs sorena-backend",
    "dev:logs:frontend": "pm2 logs sorena-frontend",
    "dev:nuke": "pm2 delete ecosystem.config.js"
  },
  "devDependencies": {
    "pm2": "^7.0.1"
  }
}
