# ── BACKEND ─────────────────────────────────────────────────────
# Copy to backend/.env and fill in real values

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/sorena_visa"

# API key for protected endpoints (GET /leads/:id, POST /handoffs/:id, GET /handoffs/:id)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HANDOFF_API_KEY="change-this-to-a-long-random-secure-string-minimum-32-chars"

# App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# SMTP (only required in production — dev mode logs to console)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="Sorena Visa <noreply@sorenavisa.co.nz>"

# ── FRONTEND ─────────────────────────────────────────────────────
# Copy to frontend/.env.local

NEXT_PUBLIC_API_URL=http://localhost:3001
