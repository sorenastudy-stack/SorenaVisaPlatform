// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  emailHash        String?   @unique
  // Option C step 1 — passwordHash is now optional. Users created
  // before Option C still have a bcrypt hash here. Users provisioned
  // via Google OAuth or first-time magic-link sign-in won't have one.
  // The login service must guard against null before calling
  // bcrypt.compare.
  passwordHash     String?
  // Option C step 1 — Google "sub" claim from OAuth ID-token. Null
  // until the user links Google. @unique prevents two app users from
  // binding the same Google account.
  googleId         String?   @unique
  role             UserRole  @default(SALES)
  // PR-STAFF-RENAME: descriptive staff-portal role. Coexists with `role`
  // (which still drives auth guards + booking's LIA gate). Null for
  // non-staff users (LEAD/STUDENT/AGENT). Backfilled from `role` by
  // migration: LIA→ADVISER, ADMIN/OWNER/SUPER_ADMIN→ADMIN,
  // SUPPORT→SUPPORT_CONSULTANT, CONSULTANT→ADMISSION_CONSULTANT.
  staffRole        StaffRole?
  canEditGlobalData Boolean  @default(false)
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // PR-CONSULT-4: staff profile fields. All three encrypted columns
  // store base64-encoded AES-256-GCM ciphertext via CryptoService.
  // countryOfResidence is plain text (ISO 3166-1 alpha-2 code) so
  // we can filter / aggregate without decrypting. All four nullable
  // because existing rows pre-date the migration.
  mobileNumber        String?
  countryOfResidence  String?
  address             String?
  emergencyContact    String?

  // PR-LIA-2: ISO 3166-1 alpha-2 codes a User is "specialised" in
  // (LIA forward-compat; the future country-router will read this).
  // PR-LIA-2 auto-assignment ignores it — empty array means "general".
  specialisedCountries String[] @default([])

  // PR-BOOKING-ADMIN-A: staff booking configuration, set by OWNER/ADMIN
  // in the /staff/team panel. All additive + defaulted.
  //   languages            — ISO 639-1 codes the staff member speaks (future
  //                          client language filter reads these).
  //   timezone             — the staff member's canonical IANA zone (source of
  //                          truth; mirrored into StaffAvailability rows
  //                          on save so the slot engine stays correct).
  //   bookableSessionTypes — which session types this staff member handles
  //                          (reuses the ConsultationType enum). LIA still
  //                          additionally requires a verified LiaProfile.
  //   bookingActive        — quick on/off without clearing config.
  languages            String[]           @default([])
  timezone             String             @default("Pacific/Auckland")
  bookableSessionTypes ConsultationType[] @default([])
  bookingActive        Boolean            @default(true)

  assignedLeads    Lead[]           @relation("LeadOwner")
  consultations    Consultation[]   @relation("ConsultationStaff")
  cases            Case[]           @relation("CaseOwner")
  // PR-LIA-2: cases where this user is the assigned LIA.
  liaCases         Case[]           @relation("CaseLia")
  // Option 1 step 4: cases where this user is the assigned
  // Support or Finance staff (parallel to liaCases).
  supportCases     Case[]           @relation("CaseSupport")
  financeCases     Case[]           @relation("CaseFinance")
  // Documents step 2: case attachments this user has uploaded.
  uploadedDocuments Document[]      @relation("DocumentUploader")
  auditLogs        AuditLog[]
  notesAuditLogs   ManagerNotesLog[]
  leadStatusChanges LeadStatusHistory[]
  contact          Contact?         @relation("StudentContact")
  assignedTickets   Ticket[]                @relation("TicketAssignee")
  createdTickets    Ticket[]                @relation("TicketCreator")
  ticketMessages    TicketMessage[]         @relation("TicketMessageSender")
  agentProfile      AgentProfile?
  agentApplications AdmissionApplication[]  @relation("ApplicationAgent")

  // PR-DASH-1: client dashboard relations. `clientVisaCases` are the
  // dashboard-side visa cases this user OWNS as a student (1:1 with
  // their VisaApplication). `consultantVisaCases` are visa cases this
  // user is ASSIGNED TO as a consultant. `assessmentReport` is the
  // Friday AI scoring bot's writeback target (1:1 per student).
  clientVisaCases       VisaCase[]        @relation("VisaCaseClient")
  consultantVisaCases   VisaCase[]        @relation("VisaCaseConsultant")
  assessmentReport      AssessmentReport?

  // PR-DASH-2: support-ticket relations.
  // `visaSupportTicketsAsClient`: tickets this user opened.
  // `visaSupportTicketsAsStaff`: tickets assigned to this user.
  // `visaSupportTicketMessages`: messages authored by this user
  // (CLIENT or STAFF).
  // `visaCaseFileNotesCreated`: file notes created by this user
  // (nullable on the row — system-generated notes have no author).
  visaSupportTicketsAsClient  VisaSupportTicket[]        @relation("VisaSupportTicketClient")
  visaSupportTicketsAsStaff   VisaSupportTicket[]        @relation("VisaSupportTicketStaff")
  visaSupportTicketMessages   VisaSupportTicketMessage[]
  visaCaseFileNotesCreated    VisaCaseFileNote[]         @relation("VisaCaseFileNoteCreator")

  // PR-DASH-3: meetings + transcripts.
  // `studentMeetings`: meetings this user is the student (client) on.
  // `consultantMeetings`: meetings this user is consulting on.
  // `transcriptUploads`: transcript metadata rows this user uploaded.
  studentMeetings       VisaMeeting[]              @relation("StudentMeetings")
  consultantMeetings    VisaMeeting[]              @relation("ConsultantMeetings")
  transcriptUploads     VisaMeetingTranscript[]

  // PR-DASH-4: in-platform AI chatbot (student-side, Pattern 1
  // escalation). Each student owns their conversations; nothing
  // crosses tenant boundaries.
  studentChatConversations VisaChatConversation[] @relation("StudentChatConversations")

  // PR-CONSULT-1: staff-roles foundation.
  // `staffAssignments`: VisaCaseAssignment rows where this user IS
  // the staff member (LIA / CONSULTANT / SUPPORT / FINANCE).
  // `assignmentsMade`: assignments this user CREATED (the actor side).
  // `ownerApprovalRequests`: requests this user (SUPER_ADMIN) raised.
  // `ownerApprovalDecisions`: requests this user (OWNER) decided.
  // `staffActiveStatus`: 1:1 soft-deactivation flag.
  staffAssignments        VisaCaseAssignment[]    @relation("StaffAssignments")
  assignmentsMade         VisaCaseAssignment[]    @relation("AssignmentsMade")
  ownerApprovalRequests   OwnerApprovalRequest[]  @relation("OwnerApprovalRequester")
  ownerApprovalDecisions  OwnerApprovalRequest[]  @relation("OwnerApprovalDecider")
  staffActiveStatus       StaffActiveStatus?      @relation("StaffActive")

  // PR-LIA-1: LegalNote rows this user authored (notes + decisions
  // on CRM-side Cases). LIA / ADMIN / SUPER_ADMIN-gated at the
  // endpoint layer.
  legalNotes              LegalNote[]             @relation("LegalNoteAuthor")

  // PR-LIA-4: CaseMessage rows this user authored (either as the LIA
  // working the case, or as the case's client replying to the thread).
  caseMessages            CaseMessage[]           @relation("CaseMessageAuthor")

  // PR-LIA-5: CaseDocumentReview rows this user authored (LIA / OWNER
  // /  ADMIN / SUPER_ADMIN — the gate is enforced at the controller).
  documentReviews         CaseDocumentReview[]    @relation("CaseDocumentReviewer")

  // PR-LIA-8: Visa rows this user issued (recorded the approval or
  // decline outcome for). Same role gate as the rest of the LIA
  // surface — LIA / ADMIN / SUPER_ADMIN / OWNER.
  issuedVisas             Visa[]                  @relation("VisaIssuer")

  // PR-LIA-10: Immigration Officer module relations.
  // `createdOfficers`     — officer profiles this user originally created.
  // `officerObservations` — observations this user authored (immutable
  //                         post-creation; only the author can delete
  //                         their own per Decision 2C).
  // `caseOfficerLinkages` — case ↔ officer links this user recorded.
  createdOfficers         ImmigrationOfficer[]               @relation("OfficerCreator")
  officerObservations     ImmigrationOfficerObservation[]    @relation("OfficerObservationAuthor")
  caseOfficerLinkages     CaseOfficerLinkage[]               @relation("CaseOfficerLinker")

  // PR-SCORECARD-1: every scorecard submission this user has made.
  // Multiple rows per user are expected (re-assessment after English
  // improvement, etc.). History is preserved.
  scorecardSubmissions    ScorecardSubmission[]              @relation("ScorecardUser")

  // PR-SCORECARD-2: marketing/affiliate link tracking.
  // `createdAffiliateAgents`  — agent profiles this OWNER/ADMIN created.
  // `createdTrackingLinks`    — tracking links this OWNER/ADMIN issued.
  createdAffiliateAgents  AffiliateAgent[]                  @relation("AffiliateAgentCreator")
  createdTrackingLinks    TrackingLink[]                    @relation("TrackingLinkCreator")

  // PR-SCORECARD-4: OWNER-editable platform settings (booking URLs +
  // Wix webhook secret) and the Wix payments matched to this user by
  // email at webhook-receive time.
  platformSettingUpdates  PlatformSetting[]                 @relation("PlatformSettingUpdater")
  wixPayments             WixPayment[]                      @relation("WixPaymentUser")

  // PR-DOCUSIGN-1: LIA credential profile (1:0..1 — only LIAs get one).
  // `liaProfile` is this user's own credential row; cascade on user delete.
  // `liaProfilesVerified` are the credential rows this user (as OWNER/ADMIN)
  // has manually verified against the IAA register; SetNull on verifier
  // delete, so the array is empty for every non-OWNER/ADMIN user.
  liaProfile              LiaProfile?                       @relation("LiaProfileOwner")
  liaProfilesVerified     LiaProfile[]                      @relation("LiaProfileVerifier")

  // PR-DOCUSIGN-1 step 2: ContractSigner rows where this user IS the
  // signer (LIA, DIRECTOR, or any client-side signer who has a User
  // account at envelope-creation time). SetNull on user hard-delete:
  // the signer row survives with its snapshotted name/email as audit
  // evidence.
  contractsSigned         ContractSigner[]

  // Option C step 1 — magic-link tokens issued to this user for
  // passwordless sign-in. Cascade on user delete (orphaned tokens
  // are useless).
  magicLinkTokens         MagicLinkToken[]

  // PR-BOOKING-1: OWNER-set weekly working hours for this user as a
  // bookable staff member. Empty for users who aren't bookable.
  staffAvailability       StaffAvailability[]               @relation("StaffAvailabilityStaff")

  // PR-BOOKING-ADMIN-B: leave / time-off rows for this user as staff.
  staffLeave              StaffLeave[]                      @relation("StaffLeaveStaff")

  // PR-STAFF-HR (Phase 3): HR self-service. Admin-set job description (plain
  // text) + who/when set it; and one current employment-contract PDF per
  // staff member (replace-on-reupload). Staff read only their own.
  jobDescription          String?
  jobDescriptionSetById   String?
  jobDescriptionSetAt     DateTime?
  staffContract           StaffContract?                    @relation("StaffContractStaff")

  // PR-WALLET (slice 1): the client's single store-credit wallet + the
  // proof-of-acceptance rows captured before a paid booking.
  wallet                  Wallet?                           @relation("WalletUser")
  policyAcceptances       PolicyAcceptance[]                @relation("PolicyAcceptanceUser")

  @@map("users")
}

// ─── OPTION C AUTH — magic-link tokens (PR-OPTION-C step 1) ──────────────────
//
// One row per issued magic-link sign-in token. The TOKEN ITSELF is never
// stored — only a server-side hash of it (SHA-256 / HMAC, picked by the
// service layer). On consumption the row is marked `consumedAt = now()`
// rather than deleted so we keep a brief audit trail of which token was
// used when. The service layer rejects rows where either:
//   - consumedAt is non-null (one-time-use enforcement), or
//   - expiresAt <= now()
//
// Cascades on User delete: tokens have no value without their owner.
// Indexed by userId for the "any active token for this user?" lookup
// the rate limiter uses.

model MagicLinkToken {
  id          String    @id @default(cuid())
  userId      String
  // Lowercased target email captured at token-create time. Verify
  // checks that the email arriving on the verify URL matches this
  // field. Stored alongside userId so a future email change on the
  // User row doesn't break in-flight tokens; the authoritative user
  // lookup at verify time still uses userId (FK).
  email       String
  tokenHash   String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Primary lookup at verify time: SHA-256(rawToken) → row. UNIQUE
  // because token collisions would be a security bug, not a data
  // problem. The @@index is explicit per the build contract — the
  // unique constraint already creates a usable index, so this is
  // belt-and-braces.
  @@unique([tokenHash])
  @@index([tokenHash])
  @@index([userId])
  @@map("magic_link_tokens")
}

// ─── ACQUISITION (existing — kept and extended) ───────────────────────────────

model Visitor {
  id          String   @id @default(cuid())
  fingerprint String?  @unique
  ipAddress   String?
  userAgent   String?
  country     String   @default("NZ")
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events           AcquisitionEvent[]
  legacyLeads      LeadCapture[]

  @@map("visitors")
}

model AcquisitionEvent {
  id        String   @id @default(cuid())
  visitorId String?
  eventType String
  eventData Json?
  page      String?
  ipAddress String?
  createdAt DateTime @default(now())

  visitor Visitor? @relation(fields: [visitorId], references: [id])

  @@index([visitorId])
  @@index([eventType])
  @@map("acquisition_events")
}

model LeadCapture {
  id                String     @id @default(cuid())
  visitorId         String?
  fullName          String
  email             String?
  emailHash         String?    @unique
  phone             String?
  whatsapp          String?
  destination       String     @default("NZ")
  studyLevel        String?
  preferredLanguage String?
  status            LeadStatus @default(NEW)
  ipAddress         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  visitor           Visitor?               @relation(fields: [visitorId], references: [id])
  attribution       LeadSourceAttribution?
  consents          ConsentRecord[]
  handoffs          LeadHandoff[]
  emailVerification EmailVerification?
  contact           Contact?               @relation(fields: [contactId], references: [id])
  contactId         String?

  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("lead_captures")
}

model LeadSourceAttribution {
  id          String   @id @default(cuid())
  leadId      String   @unique
  source      String?
  medium      String?
  campaign    String?
  referrer    String?
  landingPage String?
  createdAt   DateTime @default(now())

  lead LeadCapture @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_source_attributions")
}

model ConsentRecord {
  id        String      @id @default(cuid())
  leadId    String
  type      ConsentType
  granted   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  lead LeadCapture @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("consent_records")
}

model LeadHandoff {
  id        String        @id @default(cuid())
  leadId    String
  payload   Json
  status    HandoffStatus @default(PENDING)
  notes     String?
  sentAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lead LeadCapture @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("lead_handoffs")
}

model EmailVerification {
  id         String    @id @default(cuid())
  leadId     String    @unique
  tokenHash  String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  lead LeadCapture @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── CONTACTS ────────────────────────────────────────────────────────────────

model Contact {
  id                String    @id @default(cuid())
  fullName          String
  email             String?   @unique
  emailHash         String?   @unique
  phone             String?
  whatsapp          String?
  nationality       String?
  countryOfResidence String?
  preferredLanguage String    @default("en")
  lifecycleStage    String?
  photoUrl          String?
  dateOfBirth       DateTime?
  gender            String?
  ownerId           String?
  partnerId         String?
  archivedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  userId            String?   @unique
  user              User?     @relation("StudentContact", fields: [userId], references: [id])

  leads             Lead[]
  legacyLeadCaptures LeadCapture[]
  whatsappConversations WhatsAppConversation[]
  tickets           Ticket[]
  invoices          Invoice[]
  admissionApplications AdmissionApplication[]

  @@index([email])
  @@index([phone])
  @@map("contacts")
}

// ─── LEADS ───────────────────────────────────────────────────────────────────

model Lead {
  id                      String            @id @default(cuid())
  contactId               String
  sourceChannel           String?
  campaignId              String?
  utmSource               String?
  utmMedium               String?
  utmCampaign             String?
  firstTouchSource        String?
  lastTouchSource         String?

  leadStatus              LeadStatus        @default(NEW)
  disqualificationReason  String?
  isNurtureCandidate      Boolean           @default(false)

  readinessScore          Int?
  academicScore           Int?
  financialScore          Int?
  englishScore            Int?
  intentScore             Int?
  engagementScore         Int?
  scoreBand               ScoreBand?
  riskLevel               RiskLevel?
  riskFlags               String[]
  hardStopFlag            Boolean           @default(false)
  hardStopReason          String?
  liaEscalationRequired   Boolean           @default(false)
  executionAllowed         Boolean           @default(false)
  recommendedRoute        RecommendedRoute?
  monetisationModel       String?
  countryConfigId         String?

  aiSummary               String?
  managerNotes            String?

  ownerId                 String?
  assignedAt              DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  // PR-WIX-1: lead-stage signal captured by the Wix lead-capture
  // webhook. `currentEducationLevel` is free-text per the Wix form.
  // `externalSubmissionId` is the dedupe key (sha256 of email +
  // submittedAt + secret, first 32 chars) — unique so two retries
  // for the same submission can't double-create.
  // `countryRaw` holds the un-resolved country string when the
  // alpha-2 normaliser can't map a free-form name like "Aotearoa".
  // `webhookMetadata` keeps the original page URL / form id so we
  // can debug submissions without log archaeology.
  currentEducationLevel   String?
  externalSubmissionId    String?           @unique
  countryRaw              String?
  webhookMetadata         Json?

  // PR-SCORECARD-2: marketing attribution. Captured at scorecard
  // submission time from the sv_attribution cookie or query-string
  // fallback (ch/agent/campaign). FIRST attribution wins — once set
  // we never overwrite, so the channel that originally brought the
  // lead in keeps the credit. Both columns nullable so legacy /
  // direct-traffic leads remain valid.
  trackingLinkId          String?
  attributedAgentId       String?

  contact                 Contact           @relation(fields: [contactId], references: [id])
  owner                   User?             @relation("LeadOwner", fields: [ownerId], references: [id])
  intakeForm              IntakeForm?
  subscriptions           Subscription[]
  consultations           Consultation[]
  cases                   Case[]
  events                  CrmEvent[]
  managerNotesLogs        ManagerNotesLog[]
  statusHistory           LeadStatusHistory[]
  // PR-SCORECARD-1: the scorecard submission this Lead was auto-
  // created from. Optional (1:0..1) because legacy Leads pre-date
  // the scorecard. The inverse on ScorecardSubmission.leadId is
  // @unique so a Lead can only be the result of one submission.
  scorecardSubmission     ScorecardSubmission? @relation("ScorecardLead")

  // PR-SCORECARD-2: attribution relations.
  trackingLink            TrackingLink?     @relation("LeadAttributedLink", fields: [trackingLinkId], references: [id])
  attributedAgent         AffiliateAgent?   @relation("LeadAttributedAgent", fields: [attributedAgentId], references: [id])

  // PR-SCORECARD-4: Wix payments matched to this lead by email at
  // webhook-receive time. Match is best-effort and informational only —
  // we never auto-update lead status from a payment.
  wixPayments             WixPayment[]      @relation("WixPaymentLead")

  // PR-LIA-AUTO-ASSIGN: Stripe-webhook-event payments tied to this lead
  // (consultation, ACCOUNT_OPENING, subscription). One row per Stripe
  // paymentIntent.id; written by the /payments/webhook handler with
  // @unique idempotency on stripePaymentIntentId.
  payments                Payment[]

  @@index([contactId])
  @@index([leadStatus])
  @@index([scoreBand])
  @@index([ownerId])
  @@index([attributedAgentId])
  @@index([trackingLinkId])
  @@map("leads")
}

model ManagerNotesLog {
  id            String   @id @default(cuid())
  leadId        String
  previousValue String?
  newValue      String?
  changedById   String
  changedAt     DateTime @default(now())

  lead      Lead @relation(fields: [leadId], references: [id])
  changedBy User @relation(fields: [changedById], references: [id])

  @@index([leadId])
  @@map("manager_notes_logs")
}

model LeadStatusHistory {
  id           String      @id @default(cuid())
  leadId       String
  fromStatus   LeadStatus?
  toStatus     LeadStatus
  changedById  String
  reason       String?
  isOverride   Boolean     @default(false)
  isUndo       Boolean     @default(false)
  createdAt    DateTime    @default(now())

  lead         Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changedBy    User        @relation(fields: [changedById], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_status_history")
}

// ─── INTAKE FORM ─────────────────────────────────────────────────────────────

model IntakeForm {
  id                    String   @id @default(cuid())
  leadId                String   @unique
  highestQualification  String?
  fieldOfStudy          String?
  gpa                   Float?
  englishTestType       String?
  englishOverallScore   Float?
  englishComponentScores Json?
  financialLevel        String?
  estimatedBudgetNZD    Float?
  visaHistory           String?
  visaRejectionCount    Int      @default(0)
  visaRejectionReason   String?
  workExperienceYears   Int?
  studyIntent           String?
  preferredStartDate    String?
  preferredCountry      String   @default("NZ")
  preferredLevel        String?
  preferredField        String?
  completionPercent     Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("intake_forms")
}

// ─── SUBSCRIPTIONS ───────────────────────────────────────────────────────────

model Subscription {
  id                       String             @id @default(cuid())
  leadId                   String
  plan                     SubscriptionPlan   @default(FREE)
  stage                    SubscriptionStage  @default(STAGE_1)
  status                   SubscriptionStatus @default(ACTIVE)
  amountPaidNZD            Float?
  currency                 String             @default("NZD")
  stripeSubscriptionId     String?
  stripeCustomerId         String?
  freeResubmissionEligible Boolean            @default(false)
  startDate                DateTime?
  endDate                  DateTime?
  cancelledAt              DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([status])
  @@map("subscriptions")
}

// ─── CONSULTATIONS ───────────────────────────────────────────────────────────

model Consultation {
  id              String             @id @default(cuid())
  leadId          String
  type            ConsultationType
  assignedToId    String?
  amountNZD       Float
  currency        String             @default("NZD")
  paymentStatus   PaymentStatus      @default(PENDING)
  stripePaymentId String?
  // PR-WALLET slice 3: settlement method, set at confirm. NULL until paid
  // (and for free bookings). CARD via Stripe; WALLET via store credit.
  paidWith        PaymentMethod?
  status          ConsultationStatus @default(PENDING)
  outcomeNotes    String?
  scheduledAt     DateTime?
  completedAt     DateTime?
  // PR-BOOKING-1: native in-portal scheduling fields. All nullable so
  // existing rows backfill as NULL with no breakage.
  //   durationMinutes — session length (15/30/45), from the config map.
  //   scheduledEndAt  — denormalised scheduledAt + duration; powers the
  //                     overlap test and the partial-unique double-book
  //                     guard without recomputing on every query.
  //   bookingTimezone — IANA tz shown to the client at booking time
  //                     (for display / confirmation emails).
  //   holdExpiresAt   — optional soft-hold window for PENDING rows; the
  //                     slot engine treats a PENDING row as busy only
  //                     while holdExpiresAt > now.
  durationMinutes Int?
  scheduledEndAt  DateTime?
  bookingTimezone String?
  holdExpiresAt   DateTime?
  // PR-BOOKING-5: per-booking Jitsi meeting URL, generated once at confirm
  // (free + paid). Unguessable room. Presence also acts as the
  // "confirmation finalized" idempotency guard so retries don't re-email.
  meetingLink     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  lead       Lead  @relation(fields: [leadId], references: [id])
  assignedTo User? @relation("ConsultationStaff", fields: [assignedToId], references: [id])

  @@index([leadId])
  @@index([type])
  // PR-BOOKING-1: busy-interval lookup for the slot engine (all booked
  // sessions for a staff member within a date range).
  @@index([assignedToId, scheduledAt])
  @@map("consultations")
}

// ─── BOOKING: STAFF AVAILABILITY (PR-BOOKING-1) ───────────────────────────────
//
// OWNER-set recurring weekly working hours for a bookable staff member. One
// row per staff member per weekday-window, so they can have multiple
// windows in a day (e.g. 09:00-12:00 and 13:00-17:00 = two rows).
//
// Times are stored as minutes-from-midnight (Int) in the row's `timezone`
// (wall-clock, NOT absolute instants). The slot engine converts these to
// absolute UTC per date using the IANA `timezone`, which is what makes
// DST handling correct. `active` soft-disables a window without deleting.
//
// Date-specific overrides (days off / one-off hours) are deferred to
// Phase 2 (StaffAvailabilityException) — the slot engine is written so
// they can layer on top of this weekly grid without rework.
model StaffAvailability {
  id          String   @id @default(cuid())
  staffId     String
  dayOfWeek   Int      // 0 = Sunday … 6 = Saturday
  startMinute Int      // minutes from midnight, in `timezone`
  endMinute   Int      // minutes from midnight, in `timezone`; must be > startMinute
  timezone    String   @default("Pacific/Auckland")
  active      Boolean  @default(true)
  // Who set this window (OWNER/ADMIN). Plain nullable String with no
  // relation, mirroring the Payment.verifiedById convention.
  setById     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff       User     @relation("StaffAvailabilityStaff", fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, dayOfWeek])
  @@index([staffId, active])
  @@map("staff_availability")
}

// ─── BOOKING: STAFF LEAVE / TIME-OFF (PR-BOOKING-ADMIN-B) ─────────────────────
//
// Full-day leave for a bookable staff member. APPROVED leave is removed from
// booking availability by the slot engine (via its `excludedDates` hook):
// each leave's [startDate, endDate] inclusive range expands to YYYY-MM-DD
// calendar keys in the staff member's timezone, and those days are skipped.
//
// Dates are stored as "YYYY-MM-DD" STRINGS (wall-clock in the staff member's
// timezone) — that is exactly the key format the slot engine consumes, so
// there is no DateTime/UTC round-trip to introduce off-by-one drift.
//
// Two paths share this one model:
//   • admin sets leave directly → created with status APPROVED (slice 1).
//   • staff requests → APPROVED by an admin (REQUESTED→APPROVED) — the
//     lifecycle is modelled here but its UI is deferred to slice 2.
// Only APPROVED blocks slots; REQUESTED/REJECTED/CANCELLED never do.
enum StaffLeaveStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum StaffLeaveKind {
  DAY_OFF // full day(s); CUSTOM_HOURS (partial-day) reserved for later
}

model StaffLeave {
  id            String           @id @default(cuid())
  staffId       String
  startDate     String           // "YYYY-MM-DD" in the staff member's tz (inclusive)
  endDate       String           // "YYYY-MM-DD" (inclusive); == startDate for one day
  kind          StaffLeaveKind   @default(DAY_OFF)
  status        StaffLeaveStatus @default(REQUESTED)
  reason        String?
  // Who raised it / who approved-or-rejected it. Plain nullable Strings
  // (no relation), mirroring StaffAvailability.setById.
  requestedById String?
  approvedById  String?
  decidedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  staff         User             @relation("StaffLeaveStaff", fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, status])
  @@index([status])
  @@map("staff_leave")
}

// ─── STAFF HR: EMPLOYMENT CONTRACT (PR-STAFF-HR, Phase 3) ─────────────────────
//
// One current employment-contract PDF per staff member (userId @unique →
// re-upload replaces the row + deletes the old file). Bytes live on local
// disk under ./uploads/staff-contracts/{userId}/ — the SAME mechanism the
// student document uploaders use — and are served privately via a 5-minute
// signed-JWT token (/files/signed/:token). Never public. Uploaded only by
// ADMIN/OWNER; read only by the owning staff member (or an admin).
model StaffContract {
  id           String   @id @default(cuid())
  userId       String   @unique
  fileUrl      String   // absolute disk path (matches AdmissionDocument.fileUrl convention)
  originalName String
  mimeType     String
  sizeBytes    Int
  uploadedById String   // the ADMIN/OWNER who uploaded it
  uploadedAt   DateTime @default(now())

  staff        User     @relation("StaffContractStaff", fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_contract")
}

// ─── WALLET + STORE CREDIT (PR-WALLET, slice 1) ──────────────────────────────
//
// Client store-credit wallet. NOT cash: tiered cancellation/no-show refunds
// post CREDIT here (later slices); it is spent on future bookings; it is never
// a Stripe card refund (the captured Stripe money is kept). One wallet per
// client User. `balanceCents` is a DENORMALISED cache — the append-only
// WalletTransaction ledger is the source of truth. ALL money is Int cents.
model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balanceCents Int                 @default(0)
  currency     String              @default("NZD")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user         User                @relation("WalletUser", fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[] @relation("WalletTransactionWallet")

  @@map("wallet")
}

// Immutable, append-only ledger. Rows are NEVER updated or deleted. Each row
// snapshots `balanceAfterCents` for audit. `amountCents` is SIGNED: positive =
// credit in, negative = spend out. A partial-unique index on
// relatedConsultationId (WHERE type is a REFUND_* kind), added in the
// migration SQL, guarantees a consultation can be credited at most once.
enum WalletTransactionType {
  REFUND_CANCEL_FULL // cancel >24h before → 100% credited
  REFUND_CANCEL_LATE // cancel <24h before → 80% credited (20% retained)
  REFUND_NO_SHOW     // human-marked no-show → 75% credited (25% retained)
  SPEND_BOOKING      // credit spent on a future booking (negative amount)
  CASH_REDEMPTION    // exceptional cash-out (later PR; negative amount)
  ADJUSTMENT         // manual admin correction
}

model WalletTransaction {
  id                    String                @id @default(cuid())
  walletId              String
  amountCents           Int                   // signed: + credit / − spend
  type                  WalletTransactionType
  balanceAfterCents     Int                   // running balance snapshot (audit)
  reason                String?
  relatedConsultationId String?
  relatedPaymentId      String?
  createdById           String                // system, admin, or the client
  createdAt             DateTime              @default(now())

  wallet                Wallet                @relation("WalletTransactionWallet", fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([relatedConsultationId])
  @@map("wallet_transaction")
}

// Proof-of-acceptance of the cancellation/refund policy, captured server-side
// BEFORE a paid booking's Stripe session is created. Stores who/when + IP,
// device (user-agent), and the policy version they accepted.
model PolicyAcceptance {
  id             String   @id @default(cuid())
  userId         String
  consultationId String?
  policyVersion  String
  acceptedAt     DateTime @default(now())
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user           User     @relation("PolicyAcceptanceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consultationId])
  @@map("policy_acceptance")
}

// ─── CASES ───────────────────────────────────────────────────────────────────

model Case {
  id          String    @id @default(cuid())
  leadId      String
  stage       CaseStage @default(ADMISSION)
  status      String    @default("active")
  ownerId     String?
  // PR-LIA-2: the LIA (Legal & Immigration Adviser) currently
  // responsible for this case. Set automatically when the client
  // signs the contract (load-balanced auto-pick), reassignable by
  // OWNER / ADMIN / SUPER_ADMIN via PATCH /cases/:id/lia. NULL
  // until contract sign (or if no active LIA was available at sign
  // time — the case sits unassigned and an audit row records why).
  liaId       String?
  // PR-LIA-3: timestamp the LIA was attached to this case (or
  // reassigned to a different LIA). Set by both auto-assignment and
  // manual reassignment paths inside the same transaction that
  // touches `liaId`. NULL when no LIA is assigned. Used by the
  // productivity report for time-to-action / time-to-resolution
  // calculations and by the case-detail "Assigned N days ago" line.
  liaAssignedAt DateTime?
  // Option 1 step 4: Support and Finance slot assignees on this case.
  // Reassignable via PATCH /cases/:id/support and /cases/:id/finance.
  // Both nullable + SetNull on user delete, mirroring liaId.
  supportId   String?
  financeId   String?
  // PR-LIA-7: INZ submission lifecycle. All five fields are co-managed
  // by the InzSubmissionService — they populate together when the LIA
  // submits, clear together on revert. The receipt file metadata is
  // denormalised onto Case (rather than a separate InzSubmissionReceipt
  // model) because there's only ever one receipt per case and its
  // lifecycle is tightly bound to the submission. The actual file lives
  // at `inzReceiptFileUrl` (a filesystem path under ./uploads/inz-receipts/);
  // we use the existing /files/signed/:token route to serve it.
  // The handover (§3 / §file-storage) explains the rationale.
  inzApplicationNumber String?    @db.VarChar(128)
  inzSubmittedAt       DateTime?
  inzSubmissionNotes   String?    @db.Text
  inzReceiptFileUrl    String?
  inzReceiptFileName   String?
  inzReceiptMimeType   String?
  inzReceiptSizeBytes  Int?
  riskLevel   RiskLevel @default(LOW)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead         Lead           @relation(fields: [leadId], references: [id])
  owner        User?          @relation("CaseOwner", fields: [ownerId], references: [id])
  // PR-LIA-2: assigned LIA. SetNull on user delete so the case
  // survives an LIA being hard-deleted (PR-CONSULT-4 audit-snapshot
  // pattern handles attribution).
  lia          User?          @relation("CaseLia", fields: [liaId], references: [id], onDelete: SetNull)
  // Option 1 step 4: Support and Finance slot assignees. SetNull on
  // user delete so the case survives a hard-delete of either staff
  // role, matching the lia relation's behaviour.
  support      User?          @relation("CaseSupport", fields: [supportId], references: [id], onDelete: SetNull)
  finance      User?          @relation("CaseFinance", fields: [financeId], references: [id], onDelete: SetNull)
  applications          Application[]
  contract              Contract?
  tickets               Ticket[]
  invoices              Invoice[]
  admissionApplications AdmissionApplication[]
  // PR-LIA-1: free-form legal notes + formal decisions on this case.
  legalNotes            LegalNote[]
  // PR-LIA-4: direct LIA ↔ client thread for this case.
  caseMessages          CaseMessage[]
  // PR-LIA-5: LIA's internal-only review verdicts on this case's
  // client-uploaded documents.
  documentReviews       CaseDocumentReview[]
  // Documents step 2: R2-backed case attachments. Sibling to the
  // existing review-verdict surface above; uploads land here.
  documents             Document[]            @relation("CaseDocuments")
  // PR-LIA-8: visa outcome (1:0..1). One row per case ever — issued
  // by the LIA after INZ decides on the submitted application. NULL
  // until the LIA records the outcome via POST /cases/:id/visa/issue
  // (APPROVED) or POST /cases/:id/visa/decline (DECLINED). Reverting
  // un-issues, returning the case to INZ_SUBMITTED.
  visa                  Visa?
  // PR-LIA-10: reviewing INZ officer for this case (1:0..1). At most
  // one officer per case — the unique constraint on (caseId, officerId)
  // means re-linking the same officer is an upsert. Re-linking a
  // DIFFERENT officer would 409; LIA must unlink first.
  officerLinkage        CaseOfficerLinkage?
  // PR-LIA-AUTO-ASSIGN: Stripe-webhook-event payments tied to this case
  // (e.g. the $200 ACCOUNT_OPENING charge). The payment row is what the
  // ACCOUNT_OPENING webhook branch consults before firing the LIA
  // auto-assign — it's the durable record of the trigger event.
  payments              Payment[]

  @@index([leadId])
  @@index([stage])
  @@index([liaId])
  // Option 1 step 4: support / finance slot lookups.
  @@index([supportId])
  @@index([financeId])
  // PR-LIA-7: fast lookup by INZ reference number (e.g. "find the case
  // that owns VRC-2026-NZL-12345"). Unique constraint deliberately
  // NOT enforced — duplicate references are LIA-error territory but
  // not data-corrupting, and we don't want a UNIQUE clash to crash a
  // submit transaction.
  @@index([inzApplicationNumber])
  @@map("cases")
}

// ─── VISA OUTCOME (PR-LIA-8) ──────────────────────────────────────────
//
// One row per Case ever — set by the LIA when INZ decides on the
// submitted application. Two outcomes:
//
//   * APPROVED — visaStartDate / visaEndDate populated; visa document
//                file metadata (URL, name, mime, size) populated.
//                declineReasonEncrypted is NULL.
//   * DECLINED — declineReasonEncrypted populated (AES-256-GCM via
//                CryptoService, same envelope as LegalNote.bodyEncrypted).
//                Date and file fields are NULL.
//
// Either outcome moves the parent Case to COMPLETED. Revert un-issues:
// deletes the Visa row, sets Case.stage back to INZ_SUBMITTED, leaves
// the visa file on disk (recoverable; orphan cleanup is a future
// concern — same pattern as PR-LIA-7's revert).
//
// The visaEndDate index is a forward hook for PR-LIA-9's expiry-reminder
// query (find approved visas whose end date is within N days of now).
enum VisaIssueOutcome {
  APPROVED
  DECLINED
}

model Visa {
  id                String           @id @default(uuid())
  caseId            String           @unique
  outcome           VisaIssueOutcome
  // Approval fields (populated when outcome=APPROVED)
  visaStartDate     DateTime?
  visaEndDate       DateTime?
  visaDocumentUrl   String?          @db.Text
  visaDocumentName  String?          @db.Text
  visaDocumentMime  String?          @db.Text
  visaDocumentSize  Int?
  // Decline fields (populated when outcome=DECLINED)
  declineReasonEncrypted Bytes?
  // Common metadata
  issuedById        String
  issuedAt          DateTime         @default(now())
  notes             String?          @db.Text
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  case              Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  issuedBy          User             @relation("VisaIssuer", fields: [issuedById], references: [id])

  // PR-LIA-9: dispatched expiry-reminder ledger. One row per
  // (visa, threshold, recipient) — the unique constraint keeps the
  // sweep idempotent.
  expiryReminders   VisaExpiryReminderSent[]

  @@index([issuedById, issuedAt])
  @@index([visaEndDate])
  @@map("visas")
}

// ─── VISA EXPIRY REMINDERS (PR-LIA-9) ─────────────────────────────────
//
// One row per dispatched (or attempted) expiry-reminder email. Created
// by the daily 09:00 NZ cron in VisaExpiryService.runDailySweep. The
// unique composite (visaId, thresholdDays, recipient) makes re-running
// the sweep safe — a second pass through the same threshold for the
// same visa skips reminders that have already been recorded.
//
// emailDeliveryStatus tracks the actual SMTP outcome (PENDING / SENT
// / FAILED) so OWNER eyes-on can spot delivery problems without
// having to crawl the audit log. emailErrorMessage carries the
// nodemailer error string when status=FAILED. The audit row is
// always written regardless of delivery — the audit captures intent,
// this table captures outcome.
//
// Reminder rows are NOT deleted when a visa record is reverted (per
// the PR-LIA-9 spec — keep the historical trail). They cascade with
// the parent visa only if the visa itself is hard-deleted.
enum VisaExpiryReminderRecipient {
  LIA
  CLIENT
  OWNER
}

// ─── IMMIGRATION OFFICER MODULE (PR-LIA-10) ──────────────────────────
//
// Shared knowledge base of INZ officers. Three tables in one cluster:
//
//   * ImmigrationOfficer            — collaborative profile
//                                     (any LIA can edit per Decision 2C)
//   * ImmigrationOfficerObservation — append-only attributed notes
//                                     (authored, immutable, only the
//                                     author can delete their own)
//   * CaseOfficerLinkage            — case ↔ officer link with
//                                     snapshotted outcome at link time
//                                     (Decision 3A: outcome at the
//                                     moment of linkage, not auto-
//                                     refreshed if visa state later
//                                     changes — LIA re-links to refresh)
//
// Encryption (Decision 1A — non-negotiable):
//   * profileDescriptionEncrypted   — Bytes, AES-256-GCM via CryptoService
//   * bodyEncrypted (observations)  — Bytes, same envelope
//   * noteEncrypted (linkages)      — Bytes, same envelope
//
// Aggregates (Decision 3A — non-negotiable):
//   * No maintained counters on ImmigrationOfficer for totalCases /
//     approvedCases / declinedCases — read-time aggregation only.
//     The (officerId, linkedAt) index keeps these queries cheap.
model ImmigrationOfficer {
  id                          String                          @id @default(uuid())
  // Identity (plaintext — needed for ILIKE search + ORDER BY).
  fullName                    String                          @db.VarChar(200)
  officerCode                 String?                         @db.VarChar(64)
  branch                      String?                         @db.VarChar(200)
  countryOfPosting            String?                         @db.VarChar(120)

  // Encrypted profile description.
  profileDescriptionEncrypted Bytes?

  createdById                 String
  createdAt                   DateTime                        @default(now())
  updatedAt                   DateTime                        @updatedAt

  createdBy                   User                            @relation("OfficerCreator", fields: [createdById], references: [id])
  observations                ImmigrationOfficerObservation[]
  caseLinkages                CaseOfficerLinkage[]

  @@index([fullName])
  @@index([branch])
  @@index([countryOfPosting])
  @@map("immigration_officers")
}

model ImmigrationOfficerObservation {
  id            String              @id @default(uuid())
  officerId     String
  authorId      String
  bodyEncrypted Bytes
  // Free-form analyst tags (e.g. ["financial-scrutiny", "fast-decision"]).
  // Plaintext on purpose — these are categorical labels for future
  // analytics, not sensitive prose.
  tags          String[]            @default([])
  createdAt     DateTime            @default(now())
  // No updatedAt — Decision 2C: observations are append-only. The
  // author can delete their own row, but cannot edit (delete + repost).

  officer       ImmigrationOfficer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  author        User                @relation("OfficerObservationAuthor", fields: [authorId], references: [id])

  @@index([officerId, createdAt])
  @@index([authorId, createdAt])
  @@map("immigration_officer_observations")
}

model CaseOfficerLinkage {
  id            String              @id @default(uuid())
  caseId        String              @unique
  officerId     String
  // Snapshot of visa.outcome at the moment of linkage (null if the
  // case hasn't reached a decision yet). NOT auto-updated if the
  // visa outcome later changes — the LIA re-links to refresh.
  linkedOutcome VisaIssueOutcome?
  // Optional encrypted note about this specific officer-case interaction.
  noteEncrypted Bytes?
  linkedById    String
  linkedAt      DateTime            @default(now())

  case          Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  // Restrict on officer delete — can't drop an officer that still
  // has cases attached. LIA must unlink first (a deliberate friction
  // step so institutional knowledge isn't lost by accident).
  officer       ImmigrationOfficer  @relation(fields: [officerId], references: [id], onDelete: Restrict)
  linkedBy      User                @relation("CaseOfficerLinker", fields: [linkedById], references: [id])

  // caseId is already UNIQUE above (one officer per case max), but
  // the spec asks for the composite too — kept for documentation
  // purposes + a defensive guard if caseId UNIQUE is ever relaxed.
  @@unique([caseId, officerId])
  @@index([officerId, linkedAt])
  @@index([linkedAt])
  @@map("case_officer_linkages")
}

model VisaExpiryReminderSent {
  id                  String                       @id @default(uuid())
  visaId              String
  thresholdDays       Int
  recipient           VisaExpiryReminderRecipient
  // FK target: User. NULL for OWNER reminders that fan out to every
  // user with role=OWNER (the loop dispatches one email per OWNER but
  // we record a single ledger row to keep the unique constraint
  // useful — re-running the sweep skips the whole OWNER fan-out).
  recipientUserId     String?
  sentAt              DateTime                     @default(now())
  emailDeliveryStatus String                       @default("PENDING")
  emailErrorMessage   String?                      @db.Text

  visa                Visa                         @relation(fields: [visaId], references: [id], onDelete: Cascade)

  @@unique([visaId, thresholdDays, recipient], name: "uniq_visa_threshold_recipient")
  @@index([visaId, sentAt])
  @@index([sentAt])
  @@map("visa_expiry_reminders_sent")
}

