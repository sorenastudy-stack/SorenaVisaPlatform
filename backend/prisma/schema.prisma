// PR-DOCUSIGN-1 step 2: per-signer roles. CLIENT / LIA / DIRECTOR are
// wired at soft-launch (adult-student flow); GUARDIAN is wired at
// soft-launch too (under-18 student flow — guardian signs INSTEAD of
// the minor). PARTNER and FAMILY_MEMBER ship in the enum but no flow
// constructs envelopes with those roles until the post-launch
// family-visa work; values present now so that work is additive code,
// not an enum migration.
enum ContractSignerRole {
  CLIENT
  GUARDIAN
  PARTNER
  FAMILY_MEMBER
  LIA
  DIRECTOR
}

// PR-DOCUSIGN-1 step 2: per-signer state. Mirrors DocuSign recipient
// statuses (created/sent/delivered/completed/declined). PENDING is the
// default for non-first signers — they're queued behind a routing-order
// predecessor and haven't received the envelope yet.
enum ContractSignerStatus {
  PENDING
  SENT
  VIEWED
  SIGNED
  DECLINED
}

