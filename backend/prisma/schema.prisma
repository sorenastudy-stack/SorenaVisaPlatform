generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES
  OPERATIONS
  LIA
  SUPPORT
  STUDENT
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  INTAKE_STARTED
  INTAKE_COMPLETED
  SCORING_DONE
  QUALIFIED
  NURTURE
  EXECUTING
  CLOSED_WON
  CLOSED_LOST
  DISQUALIFIED
}

enum ScoreBand {
  LOW
  MID
  HIGH
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

enum RecommendedRoute {
  CONTENT_NURTURE
  WEBINAR
  ROADMAP
  ADMISSION_CONSULTATION
  SPECIALIST_CONSULTATION
  LIA_CONSULTATION
  EXECUTION_QUEUE
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  PREMIUM
  CONTINUITY
}

enum SubscriptionStage {
  STAGE_1
  STAGE_2
  STAGE_3
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAUSED
}

enum ConsultationType {
  ADMISSION
  LIA
}

enum ConsultationStatus {
  PENDING
  BOOKED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  AWAITING_CLIENT
  AWAITING_STAFF
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
  CASH
  OTHER
}

enum InvoicePaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CaseStage {
  ADMISSION
  VISA
  COMPLETED
  WITHDRAWN
}

enum ApplicationStatus {
  PREPARATION
  SUBMITTED
  OFFER_RECEIVED
  OFFER_ACCEPTED
  VISA_SUBMITTED
  VISA_APPROVED
  VISA_DECLINED
  WITHDRAWN
}

enum CommissionStatus {
  ESTIMATED
  CONFIRMED
  INVOICED
  PAID
  CANCELLED
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum ProviderType {
  UNIVERSITY
  POLYTECHNIC
  COLLEGE
  SCHOOL
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum QualificationLevel {
  DIPLOMA
  GRADUATE_CERTIFICATE
  GRADUATE_DIPLOMA
  BACHELOR
  POSTGRADUATE_CERTIFICATE
  POSTGRADUATE_DIPLOMA
  MASTER
  PHD
}

enum NZQFLevel {
  LEVEL_3
  LEVEL_4
  LEVEL_5
  LEVEL_6
  LEVEL_7
  LEVEL_8
  LEVEL_9
  LEVEL_10
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentStatus {
  MISSING
  UPLOADED
  VERIFIED
  REJECTED
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
}

enum EventSource {
  AI
  OPS
  LEGAL
  SYSTEM
  USER
}

enum EventProcessingStatus {
  PENDING
  PROCESSED
  FAILED
  SKIPPED
}

enum ConsentType {
  PRIVACY
  MARKETING
}

enum HandoffStatus {
  PENDING
  SENT
  FAILED
}

enum WhatsAppConversationStatus {
  NEW
  ASSIGNED
  WAITING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  emailHash        String?   @unique
  passwordHash     String
  role             UserRole  @default(SALES)
  canEditGlobalData Boolean  @default(false)
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedLeads    Lead[]           @relation("LeadOwner")
  consultations    Consultation[]   @relation("ConsultationAdviser")
  cases            Case[]           @relation("CaseOwner")
  auditLogs        AuditLog[]
  notesAuditLogs   ManagerNotesLog[]
  leadStatusChanges LeadStatusHistory[]
  contact          Contact?         @relation("StudentContact")
  assignedTickets   Ticket[]                @relation("TicketAssignee")
  createdTickets    Ticket[]                @relation("TicketCreator")
  ticketMessages    TicketMessage[]         @relation("TicketMessageSender")
  agentProfile      AgentProfile?
  agentApplications AdmissionApplication[]  @relation("ApplicationAgent")

  @@map("users")
}

// ─── ACQUISITION (existing — kept and extended) ───────────────────────────────

model Visitor {
  id          String   @id @default(cuid())
  fingerprint String?  @unique
  ipAddress   String?
  userAgent   String?
  country     String   @default("NZ")
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events           AcquisitionEvent[]
  legacyLeads      LeadCapture[]

  @@map("visitors")
}

model AcquisitionEvent {
  id        String   @id @default(cuid())
  visitorId String?
  eventType String
  eventData Json?
  page      String?
  ipAddress String?
  createdAt DateTime @default(now())

  visitor Visitor? @relation(fields: [visitorId], references: [id])

  @@index([visitorId])
  @@index([eventType])
  @@map("acquisition_events")
}

model LeadCapture {
  id                String     @id @default(cuid())
  visitorId         String?
  fullName          String
  email             String?
  emailHash         String?    @unique
  phone             String?
  whatsapp          String?
  destination       String     @default("NZ")
  studyLevel        String?
  preferredLanguage String?
  status            LeadStatus @default(NEW)
  ipAddress         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  visitor           Visitor?               @relation(fields: [visitorId], references: [id])
  attribution       LeadSourceAttribution?
  consents          ConsentRecord[]
  handoffs          LeadHandoff[]
  emailVerification EmailVerification?
  contact           Contact?               @relation(fields: [contactId], references: [id])
  contactId         String?

  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("lead_captures")
}

model LeadSourceAttribution {
  id          String   @id @default(cuid())
  leadId      String   @unique
  source      String?
  medium      String?
  campaign    String?
  referrer    String?
  landingPage String?
  createdAt   DateTime @default(now())

  lead LeadCapture @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_source_attributions")
}

model ConsentRecord {
  id        String      @id @default(cuid())
  leadId    String
  type      ConsentType
  granted   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  lead LeadCapture @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("consent_records")
}

model LeadHandoff {
  id        String        @id @default(cuid())
  leadId    String
  payload   Json
  status    HandoffStatus @default(PENDING)
  notes     String?
  sentAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lead LeadCapture @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("lead_handoffs")
}

model EmailVerification {
  id         String    @id @default(cuid())
  leadId     String    @unique
  tokenHash  String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  lead LeadCapture @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── CONTACTS ────────────────────────────────────────────────────────────────

model Contact {
  id                String    @id @default(cuid())
  fullName          String
  email             String?   @unique
  emailHash         String?   @unique
  phone             String?
  whatsapp          String?
  nationality       String?
  countryOfResidence String?
  preferredLanguage String    @default("en")
  lifecycleStage    String?
  photoUrl          String?
  dateOfBirth       DateTime?
  gender            String?
  ownerId           String?
  partnerId         String?
  archivedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  userId            String?   @unique
  user              User?     @relation("StudentContact", fields: [userId], references: [id])

  leads             Lead[]
  legacyLeadCaptures LeadCapture[]
  whatsappConversations WhatsAppConversation[]
  tickets           Ticket[]
  invoices          Invoice[]
  admissionApplications AdmissionApplication[]

  @@index([email])
  @@index([phone])
  @@map("contacts")
}

// ─── LEADS ───────────────────────────────────────────────────────────────────

model Lead {
  id                      String            @id @default(cuid())
  contactId               String
  sourceChannel           String?
  campaignId              String?
  utmSource               String?
  utmMedium               String?
  utmCampaign             String?
  firstTouchSource        String?
  lastTouchSource         String?

  leadStatus              LeadStatus        @default(NEW)
  disqualificationReason  String?
  isNurtureCandidate      Boolean           @default(false)

  readinessScore          Int?
  academicScore           Int?
  financialScore          Int?
  englishScore            Int?
  intentScore             Int?
  engagementScore         Int?
  scoreBand               ScoreBand?
  riskLevel               RiskLevel?
  riskFlags               String[]
  hardStopFlag            Boolean           @default(false)
  hardStopReason          String?
  liaEscalationRequired   Boolean           @default(false)
  executionAllowed         Boolean           @default(false)
  recommendedRoute        RecommendedRoute?
  monetisationModel       String?
  countryConfigId         String?

  aiSummary               String?
  managerNotes            String?

  ownerId                 String?
  assignedAt              DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  contact                 Contact           @relation(fields: [contactId], references: [id])
  owner                   User?             @relation("LeadOwner", fields: [ownerId], references: [id])
  intakeForm              IntakeForm?
  subscriptions           Subscription[]
  consultations           Consultation[]
  cases                   Case[]
  events                  CrmEvent[]
  managerNotesLogs        ManagerNotesLog[]
  statusHistory           LeadStatusHistory[]

  @@index([contactId])
  @@index([leadStatus])
  @@index([scoreBand])
  @@index([ownerId])
  @@map("leads")
}

model ManagerNotesLog {
  id            String   @id @default(cuid())
  leadId        String
  previousValue String?
  newValue      String?
  changedById   String
  changedAt     DateTime @default(now())

  lead      Lead @relation(fields: [leadId], references: [id])
  changedBy User @relation(fields: [changedById], references: [id])

  @@index([leadId])
  @@map("manager_notes_logs")
}

model LeadStatusHistory {
  id           String      @id @default(cuid())
  leadId       String
  fromStatus   LeadStatus?
  toStatus     LeadStatus
  changedById  String
  reason       String?
  isOverride   Boolean     @default(false)
  isUndo       Boolean     @default(false)
  createdAt    DateTime    @default(now())

  lead         Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changedBy    User        @relation(fields: [changedById], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_status_history")
}

// ─── INTAKE FORM ─────────────────────────────────────────────────────────────

model IntakeForm {
  id                    String   @id @default(cuid())
  leadId                String   @unique
  highestQualification  String?
  fieldOfStudy          String?
  gpa                   Float?
  englishTestType       String?
  englishOverallScore   Float?
  englishComponentScores Json?
  financialLevel        String?
  estimatedBudgetNZD    Float?
  visaHistory           String?
  visaRejectionCount    Int      @default(0)
  visaRejectionReason   String?
  workExperienceYears   Int?
  studyIntent           String?
  preferredStartDate    String?
  preferredCountry      String   @default("NZ")
  preferredLevel        String?
  preferredField        String?
  completionPercent     Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("intake_forms")
}

// ─── SUBSCRIPTIONS ───────────────────────────────────────────────────────────

model Subscription {
  id                       String             @id @default(cuid())
  leadId                   String
  plan                     SubscriptionPlan   @default(FREE)
  stage                    SubscriptionStage  @default(STAGE_1)
  status                   SubscriptionStatus @default(ACTIVE)
  amountPaidNZD            Float?
  currency                 String             @default("NZD")
  stripeSubscriptionId     String?
  stripeCustomerId         String?
  freeResubmissionEligible Boolean            @default(false)
  startDate                DateTime?
  endDate                  DateTime?
  cancelledAt              DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([status])
  @@map("subscriptions")
}

// ─── CONSULTATIONS ───────────────────────────────────────────────────────────

model Consultation {
  id              String             @id @default(cuid())
  leadId          String
  type            ConsultationType
  assignedToId    String?
  amountNZD       Float
  currency        String             @default("NZD")
  paymentStatus   PaymentStatus      @default(PENDING)
  stripePaymentId String?
  status          ConsultationStatus @default(PENDING)
  outcomeNotes    String?
  scheduledAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  lead       Lead  @relation(fields: [leadId], references: [id])
  assignedTo User? @relation("ConsultationAdviser", fields: [assignedToId], references: [id])

  @@index([leadId])
  @@index([type])
  @@map("consultations")
}

// ─── CASES ───────────────────────────────────────────────────────────────────

model Case {
  id          String    @id @default(cuid())
  leadId      String
  stage       CaseStage @default(ADMISSION)
  status      String    @default("active")
  ownerId     String?
  riskLevel   RiskLevel @default(LOW)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead         Lead           @relation(fields: [leadId], references: [id])
  owner        User?          @relation("CaseOwner", fields: [ownerId], references: [id])
  applications          Application[]
  contract              Contract?
  tickets               Ticket[]
  invoices              Invoice[]
  admissionApplications AdmissionApplication[]

  @@index([leadId])
  @@index([stage])
  @@map("cases")
}

// ─── APPLICATIONS ────────────────────────────────────────────────────────────

model Application {
  id              String            @id @default(cuid())
  caseId          String
  providerId      String
  programmeId     String
  intakeId        String?
  status          ApplicationStatus @default(PREPARATION)
  executionMode   String?
  liaRequired     Boolean           @default(false)
  submittedAt     DateTime?
  offerReceivedAt DateTime?
  offerAcceptedAt DateTime?
  visaSubmittedAt DateTime?
  visaDecisionAt  DateTime?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  case        Case                  @relation(fields: [caseId], references: [id])
  provider    EducationProvider     @relation(fields: [providerId], references: [id])
  programme   EducationProgramme    @relation(fields: [programmeId], references: [id])
  documents   ApplicationDocument[]
  commission  Commission?

  @@index([caseId])
  @@index([status])
  @@map("applications")
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model ApplicationDocument {
  id            String         @id @default(cuid())
  applicationId String
  type          String
  fileName      String?
  fileUrl       String?
  status        DocumentStatus @default(MISSING)
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_documents")
}

// ─── CONTRACTS ───────────────────────────────────────────────────────────────

model Contract {
  id                  String         @id @default(cuid())
  caseId              String         @unique
  templateId          String?
  docusignEnvelopeId  String?
  status              ContractStatus @default(DRAFT)
  signedAt            DateTime?
  declinedAt          DateTime?
  expiredAt           DateTime?
  signedFileUrl       String?
  auditTrailUrl       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  case Case @relation(fields: [caseId], references: [id])

  @@map("contracts")
}

// ─── COMMISSIONS ─────────────────────────────────────────────────────────────

model Commission {
  id                    String           @id @default(cuid())
  applicationId         String           @unique
  providerId            String
  programmeId           String
  commissionYear        Int              @default(1)
  commissionType        CommissionType   @default(PERCENTAGE)
  commissionValue       Float
  estimatedAmountNZD    Float?
  actualAmountNZD       Float?
  currency              String           @default("NZD")
  status                CommissionStatus @default(ESTIMATED)
  confirmedAt           DateTime?
  invoiceSentAt         DateTime?
  paidAt                DateTime?
  renewalReminderDate   DateTime?
  reminderSent          Boolean          @default(false)
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  application Application       @relation(fields: [applicationId], references: [id])
  provider    EducationProvider  @relation(fields: [providerId], references: [id])
  programme   EducationProgramme @relation(fields: [programmeId], references: [id])

  @@index([status])
  @@index([providerId])
  @@map("commissions")
}

// ─── EDUCATION PROVIDERS ─────────────────────────────────────────────────────

model EducationProvider {
  id                   String         @id @default(cuid())
  name                 String
  providerType         ProviderType
  country              String         @default("NZ")
  city                 String?
  websiteUrl           String?
  status               ProviderStatus @default(PENDING)
  agreementUrl         String?
  agreementStartDate   DateTime?
  agreementEndDate     DateTime?
  agreementRenewalDate DateTime?
  commissionY1Type     CommissionType @default(PERCENTAGE)
  commissionY1Value    Float          @default(0)
  commissionY2Type     CommissionType @default(PERCENTAGE)
  commissionY2Value    Float          @default(0)
  volumeTarget         Float?
  bonusType            CommissionType?
  bonusValue           Float?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  faculties    EducationFaculty[]
  programmes   EducationProgramme[]
  applications Application[]
  commissions  Commission[]

  @@map("education_providers")
}

model EducationFaculty {
  id         String   @id @default(cuid())
  providerId String
  name       String
  createdAt  DateTime @default(now())

  provider   EducationProvider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  programmes EducationProgramme[]

  @@index([providerId])
  @@map("education_faculties")
}

model EducationProgramme {
  id              String             @id @default(cuid())
  providerId      String
  facultyId       String?
  name            String
  level           QualificationLevel
  nzqfLevel       NZQFLevel
  durationMonths  Int?
  tuitionFeeNZD   Float?
  currency        String             @default("NZD")
  intakeMonths    Int[]
  aiPopulated     Boolean            @default(false)
  aiLastRunAt     DateTime?
  reviewStatus    ReviewStatus       @default(PENDING)
  isActive        Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  provider     EducationProvider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  faculty      EducationFaculty?       @relation(fields: [facultyId], references: [id])
  requirements ProgrammeRequirement?
  applications     Application[]
  commissions      Commission[]
  admissionChoices AdmissionProgrammeChoice[]

  @@index([providerId])
  @@index([level])
  @@index([reviewStatus])
  @@map("education_programmes")
}

model ProgrammeRequirement {
  id                       String       @id @default(cuid())
  programmeId              String       @unique
  minQualificationLevel    String?
  minGpa                   Float?
  englishTestType          String?
  englishOverallMin        Float?
  englishComponentMins     Json?
  workExperienceRequired   Boolean      @default(false)
  portfolioRequired        Boolean      @default(false)
  interviewRequired        Boolean      @default(false)
  documentsRequired        String[]
  additionalNotes          String?
  aiPopulated              Boolean      @default(false)
  reviewStatus             ReviewStatus @default(PENDING)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  programme EducationProgramme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  @@map("programme_requirements")
}

// ─── CRM EVENTS ──────────────────────────────────────────────────────────────

model CrmEvent {
  id               String                @id @default(cuid())
  eventType        String
  entityType       String?
  entityId         String?
  leadId           String?
  triggerSource    EventSource           @default(SYSTEM)
  actorType        String?
  actorId          String?
  payloadJson      Json?
  processingStatus EventProcessingStatus @default(PENDING)
  occurredAt       DateTime              @default(now())

  lead Lead? @relation(fields: [leadId], references: [id])

  @@index([eventType])
  @@index([leadId])
  @@index([occurredAt])
  @@map("crm_events")
}

// ─── WHATSAPP ────────────────────────────────────────────────────────────────

model WhatsAppConversation {
  id            String                     @id @default(cuid())
  contactId     String?
  phoneNumber   String
  status        WhatsAppConversationStatus @default(NEW)
  assignedToId  String?
  lastMessageAt DateTime?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  contact  Contact?          @relation(fields: [contactId], references: [id])
  messages WhatsAppMessage[]

  @@index([phoneNumber])
  @@index([status])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  content        String?
  messageType    String           @default("text")
  status         String?
  waMessageId    String?          @unique
  timestamp      DateTime         @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("whatsapp_messages")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@map("audit_logs")
}

// ─── KNOWLEDGE BASE (for RAG / pgvector) ─────────────────────────────────────

model KnowledgeChunk {
  id          String   @id @default(cuid())
  sourceType  String
  sourceId    String?
  sourceUrl   String?
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sourceType])
  @@map("knowledge_chunks")
}

// ─── TICKETS / IN-PORTAL MESSAGES ─────────────────────────────────────────────

model Ticket {
  id            String          @id @default(cuid())
  caseId        String?
  contactId     String
  subject       String
  status        TicketStatus    @default(OPEN)
  priority      TicketPriority  @default(NORMAL)
  assignedToId  String?
  createdById   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  closedAt      DateTime?

  case          Case?           @relation(fields: [caseId], references: [id])
  contact       Contact         @relation(fields: [contactId], references: [id])
  assignedTo    User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  createdBy     User            @relation("TicketCreator", fields: [createdById], references: [id])
  messages      TicketMessage[]

  @@index([contactId])
  @@index([caseId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id           String   @id @default(cuid())
  ticketId     String
  senderId     String
  body         String
  attachments  String[]
  isInternal   Boolean  @default(false)
  createdAt    DateTime @default(now())

  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender       User     @relation("TicketMessageSender", fields: [senderId], references: [id])

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

// ─── INVOICES & PAYMENTS ──────────────────────────────────────────────────────

model Invoice {
  id              String         @id @default(cuid())
  caseId          String?
  contactId       String
  invoiceNumber   String         @unique
  description     String
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("NZD")
  status          InvoiceStatus  @default(DRAFT)
  dueDate         DateTime?
  issuedAt        DateTime?
  paidAt          DateTime?
  stripeInvoiceId String?        @unique
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  case            Case?          @relation(fields: [caseId], references: [id])
  contact         Contact        @relation(fields: [contactId], references: [id])
  payments        Payment[]

  @@index([contactId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id                    String               @id @default(cuid())
  invoiceId             String
  amount                Decimal              @db.Decimal(10, 2)
  currency              String               @default("NZD")
  method                PaymentMethod        @default(STRIPE)
  status                InvoicePaymentStatus @default(PENDING)
  stripePaymentIntentId String?              @unique
  receivedAt            DateTime?
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  invoice               Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

// ─── ADMISSION FORM ───────────────────────────────────────────────────────────

enum AdmissionApplicationStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

enum AdmissionDocumentType {
  PASSPORT
  NZ_VISA_HISTORY
  VISA_REFUSAL_LETTER
  ENGLISH_TEST_EVIDENCE
  EDUCATION_TRANSCRIPTS
  SUPPORTING_DOCUMENT
  NOTARIZED_CERTIFICATE
  NOTARIZED_TRANSCRIPT
  VISA_PHOTO
  VISA_POLICE_CERTIFICATE
}

model AdmissionApplication {
  id            String                     @id @default(cuid())
  caseId        String
  contactId     String
  agentId       String?
  status        AdmissionApplicationStatus @default(DRAFT)
  currentStep   Int                        @default(1)
  submittedAt   DateTime?
  lockedAt      DateTime?
  termsAgreedAt DateTime?

  // Step 2 — Additional student info
  // dateOfBirth is plaintext for now; candidate for encryption in a future
  // SEC PR (same envelope as the PR-SEC3 fields). Marital status and
  // hasChildren are not PII-sensitive enough to warrant encryption.
  dateOfBirth                 DateTime?
  maritalStatus               String?
  hasChildren                 Boolean?
  phone                       String?
  phoneType                   String?
  countryOfBirth              String?
  citizenship                 String?
  ethnicity                   String?
  passportNumberEncrypted     Bytes?
  visaRefused                 Boolean?
  visaRefusalDetailsEncrypted Bytes?

  // Step 3A — English proficiency
  englishTestSat   Boolean?
  englishTestName  String?
  englishPreCourse Boolean?

  // Step 3B — Health
  hasDisability                Boolean?
  disabilityDetailsEncrypted   Bytes?
  needsEvacAssistance          Boolean?
  evacDetailsEncrypted         Bytes?
  medicalNotesEncrypted        Bytes?
  otherStudyNotesEncrypted     Bytes?

  // Step 3C — Education background
  schoolCountry          String?
  schoolName             String?
  schoolQualification    String?
  qualificationCompleted Boolean?
  qualYearStart          Int?
  qualYearEnd            Int?
  lastYearOfSchool       Int?
  highestQualification   String?

  // Step 3D — Funding
  sponsorshipProgramme String?

  // Step 5 — Parent / guardian (emergency contact)
  guardianRelationship          String?
  guardianFirstNameEncrypted    Bytes?
  guardianLastNameEncrypted     Bytes?
  guardianEmail                 String?
  guardianMobileEncrypted       Bytes?
  guardianHomePhoneEncrypted    Bytes?
  guardianAddressSameAs         Boolean?
  guardianStreetEncrypted       Bytes?
  guardianSuburbEncrypted       Bytes?
  guardianCity                  String?
  guardianState                 String?
  guardianCountry               String?
  guardianPostcodeEncrypted     Bytes?

  // Step 6 — Accommodation
  accommodationType String?

  // Step 7 — Agent / counsellor (only when agentId is set)
  counsellorFirstNameEncrypted Bytes?
  counsellorLastNameEncrypted  Bytes?
  counsellorEmail              String?
  anotherBranch                Boolean?
  branchAgentCode              String?
  branchName                   String?
  agentDeclarationAgreed       Boolean?
  agentCommentsEncrypted       Bytes?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case             Case                       @relation(fields: [caseId], references: [id])
  contact          Contact                    @relation(fields: [contactId], references: [id])
  agent            User?                      @relation("ApplicationAgent", fields: [agentId], references: [id])
  programmeChoices AdmissionProgrammeChoice[]
  educationEntries AdmissionEducationEntry[]
  documents        AdmissionDocument[]
  visaApplication  VisaApplication?

  @@index([caseId])
  @@index([contactId])
  @@index([status])
  @@map("admission_applications")
}

model AdmissionEducationEntry {
  id                     String   @id @default(cuid())
  admissionApplicationId String
  qualificationLevel     String
  institutionName        String
  country                String
  // fieldOfStudy is required at the application layer (PR-C1) but stays
  // nullable in the DB to accept legacy rows that pre-date the requirement.
  fieldOfStudy           String?
  startYear              Int?
  endYear                Int?
  completed              Boolean  @default(false)
  // PR-C1: student indicates "I have not received the certificate yet".
  // Informational for now; the submit-gate that uses it ships in PR-C2.
  certificateNotReceived Boolean  @default(false)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  admissionApplication AdmissionApplication @relation(fields: [admissionApplicationId], references: [id], onDelete: Cascade)
  documents            AdmissionDocument[]
  visaSupplement       VisaEducationSupplement?

  @@index([admissionApplicationId])
  @@map("admission_education_entries")
}

model AdmissionProgrammeChoice {
  id                     String   @id @default(cuid())
  admissionApplicationId String
  programmeId            String
  intakeMonth            Int
  intakeYear             Int
  priority               Int
  createdAt              DateTime @default(now())

  admissionApplication AdmissionApplication @relation(fields: [admissionApplicationId], references: [id], onDelete: Cascade)
  programme            EducationProgramme   @relation(fields: [programmeId], references: [id])

  @@index([admissionApplicationId])
  @@map("admission_programme_choices")
}

model AdmissionDocument {
  id                     String                @id @default(cuid())
  admissionApplicationId String
  educationEntryId       String?
  documentType           AdmissionDocumentType
  fileName               String
  fileUrl                String
  mimeType               String
  fileSizeBytes          Int
  uploadedAt             DateTime              @default(now())

  admissionApplication AdmissionApplication      @relation(fields: [admissionApplicationId], references: [id], onDelete: Cascade)
  educationEntry       AdmissionEducationEntry?  @relation(fields: [educationEntryId], references: [id], onDelete: Cascade)

  @@index([admissionApplicationId])
  @@index([educationEntryId])
  @@map("admission_documents")
}

model AgentProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  agencyName String
  agencyCode String   @unique
  branchName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_profiles")
}

// ─── VISA APPLICATION (INZ 1200) ──────────────────────────────────────────────
// One row per admission application. Grows section by section as the student
// works through the INZ 1200 form. All editable fields stay nullable so the
// student can save a partial draft; required-ness is enforced in the UI and
// at save-time. otherNames + nationalId are PII — encrypted via CryptoService
// using the same AES-256-GCM envelope as admission's PR-SEC3 columns.
model VisaApplication {
  id                      String   @id @default(cuid())
  applicationId           String   @unique

  // Section 1 — Identity Details
  hasMononym              Boolean?
  middleNames             String?
  hasUsedOtherNames       Boolean?
  otherNamesEncrypted     Bytes?
  countryWhenSubmitting   String?
  prevAppliedNzVisa       Boolean?
  prevRequestedNzeta      Boolean?
  everTravelledNz         Boolean?
  totalNzTime24Plus       Boolean?
  passportIssueDate       DateTime?
  passportExpiryDate      DateTime?
  passportCountryOfIssue  String?
  passportGender          String?
  stateOfBirth            String?
  cityOfBirth             String?
  hasNationalId           Boolean?
  nationalIdEncrypted     Bytes?
  nationalIdCountry       String?

  // Section 2 — Address and contact information (PR-VISA2)
  physicalStreetEncrypted     Bytes?
  physicalSuburb              String?
  physicalCity                String?
  physicalState               String?
  physicalPostcode            String?
  physicalCountry             String?
  postalSameAsPhysical        Boolean?
  postalStreetEncrypted       Bytes?
  postalSuburb                String?
  postalCity                  String?
  postalState                 String?
  postalPostcode              String?
  postalCountry               String?
  preferredContactCountryCode    String?
  preferredContactNumber         String?
  alternativeContactCountryCode  String?
  alternativeContactNumber       String?

  // Section 3 — Eligibility (PR-VISA3)
  // Study history
  holdsNzStudentVisa             Boolean?
  // Offer of Place assistance
  usedEducationAgent             Boolean?
  agentOrganisationName          String?
  agentCountry                   String?
  agentGivenName                 String?
  agentSurname                   String?
  agentEmail                     String?
  // Study details
  studyingSchoolLevel            Boolean?
  studyingMastersOrPhd           String?
  educationProviderName          String?
  studyLocation                  String?
  courseRequiresOtherLocation    Boolean?
  courseProgrammeName            String?
  courseStartDate                DateTime?
  courseEndDate                  DateTime?
  intendedArrivalDate            DateTime?
  // PhD details — only relevant when studyingMastersOrPhd = "PHD"
  phdDiscipline                  String?
  phdSubject                     String?
  phdSupervisorTitle             String?
  phdSupervisorGivenName         String?
  phdSupervisorSurname           String?
  phdSupervisorOrganisation      String?
  phdPublishedPapers             Boolean?
  phdSupervisorOutsideNz         Boolean?
  // Student identification number
  providerIssuedStudentId        Boolean?
  studentIdNumber                String?
  // Your situation and plans — six free-text fields are PII (AES-256-GCM)
  homeCommitmentsEncrypted       Bytes?
  studyRelatesToPrevious         Boolean?
  studyRelatesDetailsEncrypted   Bytes?
  whyStudyNzEncrypted            Bytes?
  whyThisProviderEncrypted       Bytes?
  howCourseBenefitsEncrypted     Bytes?
  plansAfterStudyEncrypted       Bytes?
  studyingMultiYear              Boolean?

  // Section 4 — Character (PR-VISA4)
  // Character details (4 mandatory Y/N declarations)
  everConvicted                  Boolean?
  underInvestigation             Boolean?
  everDeportedExcluded           Boolean?
  everRefusedVisa                Boolean?
  // Police certificate from the country of citizenship — the file itself
  // is uploaded via the admission documents pipeline with documentType =
  // VISA_POLICE_CERTIFICATE; these three columns capture the cert metadata.
  policeCertIssueDate            DateTime?
  policeCertCountryOfIssue       String?
  policeCertInEnglish            Boolean?
  // Other citizenships + 5+ years branch (no further inputs in this PR)
  holdsOtherCitizenships         Boolean?
  livedOtherCountry5Years        Boolean?

  // Section 5 — Health (PR-VISA5)
  hasTuberculosis                Boolean?
  needsRenalDialysis             Boolean?
  hasMedicalCondition            Boolean?
  needsResidentialCare           Boolean?
  isPregnant                     Boolean?
  intendedLengthOfStay           String?
  hadMedicalExam                 Boolean?
  medicalRefNumber               String?
  tbCountriesNoMore              Boolean?
  insuranceDeclarationAgreed     Boolean?
  publicHealthAckAgreed          Boolean?

  // Section 7 — Employment history (PR-VISA7)
  everGovernmentEmployed         Boolean?
  everPrisonGuard                Boolean?
  currentlyWorking               Boolean?
  hadPreviousEmployment          Boolean?
  everUnemployed                 Boolean?

  // Section 8 — Relationships (PR-VISA8)
  // Note: relationshipStatus + hasChildren are sourced read-only from
  // admission.maritalStatus + admission.hasChildren (see PR-VISA8 reuse
  // notes). Only the three Y/N gates that have no admission equivalent
  // live here.
  hasFormerPartners              Boolean?
  hasSiblings                    Boolean?
  hasNzContacts                  Boolean?

  // Section 9 — Background details (PR-VISA9). Flat set of Y/N
  // declarations; all nullable so partial drafts can save.
  heldReligiousCulturalPosition  Boolean?
  heldPoliticalAppointment       Boolean?
  hadPoliticalAssociation        Boolean?
  associatedIntelligenceAgency   Boolean?
  witnessedIllTreatment          Boolean?
  involvedArmedConflict          Boolean?
  associatedViolentGroup         Boolean?
  involvedWarCrimes              Boolean?
  memberLiberationMilitia        Boolean?
  everDetainedImprisoned         Boolean?

  currentStep             Int      @default(1)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  admissionApplication    AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  otherCitizenships       VisaOtherCitizenship[]
  tbRiskCountries         VisaTbRiskCountry[]
  educationSupplements    VisaEducationSupplement[]
  employmentEntries       VisaEmploymentEntry[]
  unemploymentEntries     VisaUnemploymentEntry[]
  partner                 VisaPartner?
  formerPartners          VisaFormerPartner[]
  children                VisaChild[]
  parents                 VisaParent[]
  siblings                VisaSibling[]
  nzContacts              VisaNzContact[]

  @@map("visa_applications")
}

// Step 8 (PR-VISA8) — Relationships. Six new tables; all third-party
// name fields and passport numbers / phone numbers / street addresses
// are PII and stored encrypted (AES-256-GCM via CryptoService, same
// envelope as the earlier Visa Section PII columns).
//
// visa_partner is singleton (UNIQUE on visaApplicationId) — at most one
// current partner per visa application. Everything else is a repeating
// child table with sortOrder for stable render order. Cascade on the
// parent FK so the visa_application's delete tears everything down.

model VisaPartner {
  id                       String   @id @default(cuid())
  visaApplicationId        String   @unique
  relationshipToApplicant  String?
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  gender                   String?
  dateOfBirth              DateTime?
  relationshipStatus       String?
  countryOfBirth           String?
  stateOfBirth             String?
  cityOfBirth              String?
  nationality              String?
  countryOfResidence       String?
  occupation               String?
  holdsPassport            Boolean?
  passportNumberEncrypted  Bytes?
  passportCountryOfIssue   String?
  passportIssueDate        DateTime?
  passportExpiryDate       DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@map("visa_partner")
}

model VisaFormerPartner {
  id                    String   @id @default(cuid())
  visaApplicationId     String
  givenNameEncrypted    Bytes?
  middleNamesEncrypted  Bytes?
  surnameEncrypted      Bytes?
  gender                String?
  dateOfBirth           DateTime?
  relationshipStatus    String?
  countryOfBirth        String?
  nationality           String?
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  visaApplication       VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_former_partners")
}

model VisaChild {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  gender                   String?
  dateOfBirth              DateTime?
  countryOfBirth           String?
  nationality              String?
  relationshipToApplicant  String?
  livesWithApplicant       Boolean?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_children")
}

model VisaParent {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  relationshipToApplicant  String?
  isDeceased               Boolean?
  gender                   String?
  dateOfBirth              DateTime?
  dateOfBirthUnknown       Boolean?
  relationshipStatus       String?
  countryOfBirth           String?
  citizenship              String?
  countryOfResidence       String?
  occupation               String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_parents")
}

model VisaSibling {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  relationshipToApplicant  String?
  gender                   String?
  dateOfBirth              DateTime?
  dateOfBirthUnknown       Boolean?
  relationshipStatus       String?
  countryOfBirth           String?
  citizenship              String?
  countryOfResidence       String?
  occupation               String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_siblings")
}

model VisaNzContact {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  relationshipToApplicant  String?
  phoneEncrypted           Bytes?
  email                    String?
  streetEncrypted          Bytes?
  suburb                   String?
  townCity                 String?
  region                   String?
  postcode                 String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_nz_contacts")
}

// Step 7 employment history (PR-VISA7). One table covers both the
// single CURRENT job and any number of PREVIOUS jobs — distinguished by
// entryKind. duties is PII (free-text role description) and stored
// encrypted via CryptoService using the standard AES-256-GCM envelope.
// startDate carries month-precision (we store the 1st of the month);
// endDate is null on the CURRENT row.
model VisaEmploymentEntry {
  id                   String   @id @default(cuid())
  visaApplicationId    String
  entryKind            String
  startDate            DateTime?
  endDate              DateTime?
  roleTitle            String?
  dutiesEncrypted      Bytes?
  countryOfWork        String?
  stateOfWork          String?
  supervisorName       String?
  organisationField    String?
  organisationCountry  String?
  organisationState    String?
  employerName         String?
  employerStreet       String?
  employerSuburb       String?
  employerTownCity     String?
  employerSubregion    String?
  employerRegion       String?
  employerPostcode     String?
  employerPhone        String?
  employerEmail        String?
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  visaApplication      VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_employment_entries")
}

// Step 7 unemployment / unpaid-service periods (PR-VISA7). Both
// free-text descriptions are PII and stored encrypted.
model VisaUnemploymentEntry {
  id                          String   @id @default(cuid())
  visaApplicationId           String
  startDate                   DateTime?
  endDate                     DateTime?
  activityEncrypted           Bytes?
  financialSupportEncrypted   Bytes?
  sortOrder                   Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  visaApplication             VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_unemployment_entries")
}

// Visa-side extras for an admission education entry (PR-VISA6). One row
// per admission_education_entry — the admission row holds the data INZ
// already collects via the admission form (qualification level, field of
// study, institution name, country, start/end YEAR, completed/awarded
// status). This supplement holds only what INZ Section 6 needs on top:
//   * startMonth / endMonth — admission stores year-only
//   * institutionState / institutionTown — admission has no address fields
//   * qualificationAwarded — distinct semantic from admission's
//     `completed` (student-finished) vs `certificateNotReceived` (cert in
//     transit). INZ asks specifically whether the institution conferred
//     the qualification.
// Cascade-deletes with either parent so a deleted admission entry never
// strands an orphan supplement.
model VisaEducationSupplement {
  id                    String   @id @default(cuid())
  visaApplicationId     String
  educationEntryId      String   @unique
  startMonth            Int?
  endMonth              Int?
  institutionState      String?
  institutionTown       String?
  qualificationAwarded  Boolean?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  visaApplication       VisaApplication         @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)
  educationEntry        AdmissionEducationEntry @relation(fields: [educationEntryId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_education_supplements")
}

// Repeating rows for the TB-risk countries block (PR-VISA5). One row per
// country the student has visited or lived in over the last 5 years.
// Same shape as VisaOtherCitizenship — live-API per row (POST/PATCH/DELETE
// endpoints), cascade-deleted with the parent visa application.
model VisaTbRiskCountry {
  id                String   @id @default(cuid())
  visaApplicationId String
  country           String
  totalDurationDays Int
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  visaApplication   VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_tb_risk_countries")
}

// Repeating rows for "Do you hold any other citizenships?" = Yes
// (PR-VISA4 fix). Mirrors the admission_education_entries pattern: each
// row is mutated via its own POST/PATCH/DELETE endpoint, the rows are
// returned alongside the parent application on GET, and they cascade
// delete when the parent visa_application is removed. When the student
// toggles holdsOtherCitizenships back to false on save, the service
// deletes every row atomically — no orphans.
model VisaOtherCitizenship {
  id                String   @id @default(cuid())
  visaApplicationId String
  country           String
  holdsPassport     Boolean
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  visaApplication   VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_other_citizenships")
}
