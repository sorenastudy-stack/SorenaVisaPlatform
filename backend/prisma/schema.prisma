// ─── CONTRACTS ───────────────────────────────────────────────────────────────

model Contract {
  id                  String         @id @default(cuid())
  caseId              String         @unique
  templateId          String?
  docusignEnvelopeId  String?
  status              ContractStatus @default(DRAFT)
  signedAt            DateTime?
  declinedAt          DateTime?
  expiredAt           DateTime?
  signedFileUrl       String?
  auditTrailUrl       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  case Case @relation(fields: [caseId], references: [id])

  // PR-DOCUSIGN-1 step 2: per-party signer rows. Sequential routing —
  // one row per signer slot; "fully signed" is derived from all rows
  // having signedAt non-null (no PARTIALLY_SIGNED enum value).
  signers ContractSigner[]

  @@map("contracts")
}

// ─── CONTRACT SIGNERS (PR-DOCUSIGN-1 step 2) ─────────────────────────────────
// One row per party on a contract envelope. Sequential routing — lowest
// routingOrder signs first, then envelope advances to the next slot.
//
// Launch flows (the only two wired at soft-launch):
//   • Adult student:    CLIENT (1)   → LIA (2) → DIRECTOR (3)
//   • Under-18 student: GUARDIAN (1) → LIA (2) → DIRECTOR (3)
//     (the minor does NOT sign; the guardian signs on their behalf, with
//     the minor's name captured in signingOnBehalfOf)
//
// PARTNER and FAMILY_MEMBER values exist in the role enum so the post-
// launch family-visa flow can add them without an enum migration — but
// no flow constructs envelopes with those roles yet.
//
// Identity is SNAPSHOTTED at envelope-creation time (signerName +
// signerEmail). If a User's email later changes, this row keeps what
// was actually sent. userId FK is optional and SetNull on hard-delete:
// the row survives with the snapshotted identity as audit evidence —
// mirrors actorNameSnapshot in audit_logs.
//
// Why @@unique([contractId, role]) is intentionally NOT here: a family-
// visa envelope can carry multiple family-type signers (partner +
// family member) on the same contract. routingOrder is the slot-
// uniqueness guarantee; role is descriptive, not constraint-bearing.
model ContractSigner {
  id                    String                @id @default(cuid())
  contractId            String

  role                  ContractSignerRole
  routingOrder          Int                                          // 1, 2, 3, … — matches DocuSign routingOrder

  // Identity snapshot — durable truth, what the envelope was actually
  // addressed to at send time. NOT updated when the underlying User /
  // Contact later changes their name or email.
  signerName            String
  signerEmail           String

  // GUARDIAN only — the name of the minor student this guardian is
  // authorized to sign on behalf of. Null for every other role.
  // Provides the legal record of the guardian-to-minor relationship
  // that backed this signature. Stored as a plain name snapshot (the
  // minor is not a signer; no FK or status of their own). App-layer
  // invariant: role === 'GUARDIAN' ⇒ signingOnBehalfOf IS NOT NULL.
  signingOnBehalfOf     String?

  // Optional FK to User. Populated for LIA + DIRECTOR rows (always
  // staff). Populated for CLIENT / GUARDIAN / PARTNER / FAMILY_MEMBER
  // rows when that person has a User account at envelope-creation
  // time. SetNull on user hard-delete — the snapshotted identity
  // above survives.
  userId                String?

  // Per-signer state — independent of the parent Contract.status,
  // which mirrors the envelope-level state DocuSign reports back.
  // "Fully signed" is derived from child rows (all signedAt non-null),
  // not stored as a dedicated ContractStatus value.
  status                ContractSignerStatus  @default(PENDING)
  viewedAt              DateTime?
  signedAt              DateTime?
  declinedAt            DateTime?
  declineReason         String?                                      // DocuSign returns a free-text reason

  // DocuSign-side recipient id (string "1"/"2"/"3"/… within an envelope).
  // Webhook payloads reference recipients by this id; we look up the
  // ContractSigner row by (contractId, docusignRecipientId).
  docusignRecipientId   String?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  contract              Contract              @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user                  User?                 @relation(fields: [userId],     references: [id], onDelete: SetNull)

  @@unique([contractId, routingOrder])    // slot uniqueness — no two signers share a position
  @@index([contractId])
  @@index([userId])
  @@map("contract_signers")
}

// ─── LEGAL NOTES (PR-LIA-1) ──────────────────────────────────────────────────
//
// Free-form notes and formal decisions attached to a CRM-side Case by
// the LIA (Legal & Immigration Adviser) team. Two row variants:
//   * Note      — decision IS NULL, decisionReasonEncrypted IS NULL.
//                 `bodyEncrypted` holds the LIA's free-form note.
//   * Decision  — decision IS NOT NULL. Both encrypted body and
//                 decisionReasonEncrypted are populated (the body is
//                 a one-line system summary of the decision; the
//                 reason carries the LIA's written justification).
//
// Both encrypted columns hold AES-256-GCM ciphertext via CryptoService
// (same envelope as every other PII column in the project).
model LegalNote {
  id                       String         @id @default(uuid())
  caseId                   String
  authorId                 String
  bodyEncrypted            Bytes
  decision                 LegalDecision?
  decisionReasonEncrypted  Bytes?
  createdAt                DateTime       @default(now())

  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation("LegalNoteAuthor", fields: [authorId], references: [id])

  @@index([caseId, createdAt])
  @@map("legal_notes")
}

// ─── CASE MESSAGES (PR-LIA-4) ────────────────────────────────────────────────
//
// Direct messaging thread between the LIA and the case's client.
// Both encrypted body and (optional) document-request type live on
// the same row — the shape variant is determined by `kind`.
//
// Read-tracking is per-thread per-viewer (readByLia / readByClient),
// not per-message: when the LIA fetches the thread, every unread
// CLIENT-authored row flips to readByLia=true in one update. Same on
// the client side with the directions reversed. A single
// CASE_MESSAGE_READ audit row captures the flip (count, not row-by-row).
//
// fulfilledByFileId is the optional link to the VisaSupportingDocument
// the client used to fulfil a DOCUMENT_REQUEST. See the PR-LIA-4
// handover for why VisaSupportingDocument (and not e.g. ApplicationDocument)
// is the chosen FK target.
model CaseMessage {
  id                String                  @id @default(uuid())
  caseId            String
  authorId          String
  authorRole        CaseMessageAuthorRole
  kind              CaseMessageKind         @default(MESSAGE)
  bodyEncrypted     Bytes
  requestedDocType  String?
  fulfilledByFileId String?
  fulfilledAt       DateTime?
  readByClient      Boolean                 @default(false)
  readByLia         Boolean                 @default(false)
  createdAt         DateTime                @default(now())

  case            Case                    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author          User                    @relation("CaseMessageAuthor", fields: [authorId], references: [id])
  fulfilledByFile VisaSupportingDocument? @relation("CaseMessageFulfilment", fields: [fulfilledByFileId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([caseId, readByClient])
  @@index([caseId, readByLia])
  @@map("case_messages")
}

// ─── CASE DOCUMENT REVIEWS (PR-LIA-5) ────────────────────────────────────────
//
// LIA's internal-only verdict on a client-uploaded document. The
// source document lives in one of three tables (AdmissionDocument,
// ApplicationDocument, VisaSupportingDocument) — we identify it by
// `(source, sourceRowId)` rather than a typed FK so we don't have to
// modify any of the source upload models. UNREVIEWED is the implicit
// default (no row exists); only APPROVED / REJECTED rows are stored.
//
// `reasonEncrypted` carries the LIA's free-form justification in the
// same AES-256-GCM envelope as LegalNote.bodyEncrypted. Required for
// both APPROVED and REJECTED. Re-reviewing a document upserts the
// existing row (UNIQUE on (source, sourceRowId)).
//
// Client-visible: NO. The PR-LIA-5 design is internal-only — if a
// re-upload is needed, the LIA messages the client via PR-LIA-4.
// Forward-compat would be a "publishToClient: Boolean" flag.
model CaseDocumentReview {
  id              String                     @id @default(uuid())
  caseId          String
  source          CaseDocumentReviewSource
  sourceRowId     String
  status          CaseDocumentReviewStatus
  reasonEncrypted Bytes
  reviewedById    String
  reviewedAt      DateTime                   @default(now())

  case            Case                       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reviewedBy      User                       @relation("CaseDocumentReviewer", fields: [reviewedById], references: [id])

  @@unique([source, sourceRowId])
  @@index([caseId, reviewedAt])
  @@map("case_document_reviews")
}

