// PR-LIA-AUTO-ASSIGN Phase 6 — Stripe-webhook-event payment log.
//
// One row per `paymentIntent.succeeded` event from Stripe. The unique
// constraint on `stripePaymentIntentId` is the idempotency key: when
// Stripe retries a webhook (it will, on any non-2xx response or just
// at random), the `prisma.payment.create` call hits a P2002 collision
// and the handler short-circuits the rest of the work (no double
// emails, no double `assignLiaToCase`, no double `activateSubscription`).
//
// `leadId` is always set — every Stripe link is created with the lead
// in metadata. `caseId` is optional: the ACCOUNT_OPENING charge sets it
// (since the contract was just signed and the case is known); the
// consultation and subscription flows don't.
//
// `paymentType` is the discriminator written into the Stripe link
// metadata at creation time. Today's known values: 'ACCOUNT_OPENING',
// 'consultation', 'subscription'. When the webhook receives metadata
// it doesn't recognise we record 'unknown' rather than silently drop —
// downstream queries can use that to flag suspect events for review.
//
// `metadata` snapshots the full Stripe-side metadata blob so we can
// reconstruct what link produced the charge without going to Stripe.
model Payment {
  id                    String   @id @default(cuid())
  stripePaymentIntentId String   @unique
  leadId                String
  caseId                String?
  paymentType           String
  amount                Int
  currency              String   @default("nzd")
  status                String
  metadata              Json?
  createdAt             DateTime @default(now())

  // Phase 6.5 — finance verification workflow.
  //
  // verifiedById is a plain nullable String with NO Prisma relation,
  // following the existing CrmEvent.actorId convention — a relation
  // would force a back-relation field on the User model, which Phase
  // 6.5 explicitly avoids.
  //
  // receiptDocumentId stays nullable at the DB level even though the
  // app REQUIRES a receipt for new manual payments: existing Stripe
  // rows have no receipt, so a NOT NULL column would break them. The
  // service layer enforces "receipt required when paymentType=manual".
  verificationStatus PaymentVerificationStatus @default(PENDING)
  verifiedById       String?
  verifiedAt         DateTime?
  verificationNote   String?
  receiptDocumentId  String?

  lead Lead  @relation(fields: [leadId], references: [id])
  case Case? @relation(fields: [caseId], references: [id])

  @@index([leadId])
  @@index([caseId])
  @@map("payments")
}

// ─── ADMISSION FORM ───────────────────────────────────────────────────────────

enum AdmissionApplicationStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

enum AdmissionDocumentType {
  PASSPORT
  NZ_VISA_HISTORY
  VISA_REFUSAL_LETTER
  ENGLISH_TEST_EVIDENCE
  EDUCATION_TRANSCRIPTS
  SUPPORTING_DOCUMENT
  NOTARIZED_CERTIFICATE
  NOTARIZED_TRANSCRIPT
  VISA_PHOTO
  VISA_POLICE_CERTIFICATE
}

model AdmissionApplication {
  id            String                     @id @default(cuid())
  caseId        String
  contactId     String
  agentId       String?
  status        AdmissionApplicationStatus @default(DRAFT)
  currentStep   Int                        @default(1)
  submittedAt   DateTime?
  lockedAt      DateTime?
  termsAgreedAt DateTime?

  // Step 2 — Additional student info
  // dateOfBirth is plaintext for now; candidate for encryption in a future
  // SEC PR (same envelope as the PR-SEC3 fields). Marital status and
  // hasChildren are not PII-sensitive enough to warrant encryption.
  dateOfBirth                 DateTime?
  maritalStatus               String?
  hasChildren                 Boolean?
  phone                       String?
  phoneType                   String?
  countryOfBirth              String?
  citizenship                 String?
  ethnicity                   String?
  passportNumberEncrypted     Bytes?
  visaRefused                 Boolean?
  visaRefusalDetailsEncrypted Bytes?

  // Step 3A — English proficiency
  englishTestSat   Boolean?
  englishTestName  String?
  englishPreCourse Boolean?

  // Step 3B — Health
  hasDisability                Boolean?
  disabilityDetailsEncrypted   Bytes?
  needsEvacAssistance          Boolean?
  evacDetailsEncrypted         Bytes?
  medicalNotesEncrypted        Bytes?
  otherStudyNotesEncrypted     Bytes?

  // Step 3C — Education background
  schoolCountry          String?
  schoolName             String?
  schoolQualification    String?
  qualificationCompleted Boolean?
  qualYearStart          Int?
  qualYearEnd            Int?
  lastYearOfSchool       Int?
  highestQualification   String?

  // Step 3D — Funding
  sponsorshipProgramme String?

  // Step 5 — Parent / guardian (emergency contact)
  guardianRelationship          String?
  guardianFirstNameEncrypted    Bytes?
  guardianLastNameEncrypted     Bytes?
  guardianEmail                 String?
  guardianMobileEncrypted       Bytes?
  guardianHomePhoneEncrypted    Bytes?
  guardianAddressSameAs         Boolean?
  guardianStreetEncrypted       Bytes?
  guardianSuburbEncrypted       Bytes?
  guardianCity                  String?
  guardianState                 String?
  guardianCountry               String?
  guardianPostcodeEncrypted     Bytes?

  // Step 6 — Accommodation
  accommodationType String?

  // Step 7 — Agent / counsellor (only when agentId is set)
  counsellorFirstNameEncrypted Bytes?
  counsellorLastNameEncrypted  Bytes?
  counsellorEmail              String?
  anotherBranch                Boolean?
  branchAgentCode              String?
  branchName                   String?
  agentDeclarationAgreed       Boolean?
  agentCommentsEncrypted       Bytes?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case             Case                       @relation(fields: [caseId], references: [id])
  contact          Contact                    @relation(fields: [contactId], references: [id])
  agent            User?                      @relation("ApplicationAgent", fields: [agentId], references: [id])
  programmeChoices AdmissionProgrammeChoice[]
  educationEntries AdmissionEducationEntry[]
  documents        AdmissionDocument[]
  visaApplication  VisaApplication?

  @@index([caseId])
  @@index([contactId])
  @@index([status])
  @@map("admission_applications")
}

model AdmissionEducationEntry {
  id                     String   @id @default(cuid())
  admissionApplicationId String
  qualificationLevel     String
  institutionName        String
  country                String
  // fieldOfStudy is required at the application layer (PR-C1) but stays
  // nullable in the DB to accept legacy rows that pre-date the requirement.
  fieldOfStudy           String?
  startYear              Int?
  endYear                Int?
  completed              Boolean  @default(false)
  // PR-C1: student indicates "I have not received the certificate yet".
  // Informational for now; the submit-gate that uses it ships in PR-C2.
  certificateNotReceived Boolean  @default(false)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  admissionApplication AdmissionApplication @relation(fields: [admissionApplicationId], references: [id], onDelete: Cascade)
  documents            AdmissionDocument[]
  visaSupplement       VisaEducationSupplement?

  @@index([admissionApplicationId])
  @@map("admission_education_entries")
}

model AdmissionProgrammeChoice {
  id                     String   @id @default(cuid())
  admissionApplicationId String
  programmeId            String
  intakeMonth            Int
  intakeYear             Int
  priority               Int
  createdAt              DateTime @default(now())

  admissionApplication AdmissionApplication @relation(fields: [admissionApplicationId], references: [id], onDelete: Cascade)
  programme            EducationProgramme   @relation(fields: [programmeId], references: [id])

  @@index([admissionApplicationId])
  @@map("admission_programme_choices")
}

model AdmissionDocument {
  id                     String                @id @default(cuid())
  admissionApplicationId String
  educationEntryId       String?
  documentType           AdmissionDocumentType
  fileName               String
  fileUrl                String
  mimeType               String
  fileSizeBytes          Int
  uploadedAt             DateTime              @default(now())

  admissionApplication AdmissionApplication      @relation(fields: [admissionApplicationId], references: [id], onDelete: Cascade)
  educationEntry       AdmissionEducationEntry?  @relation(fields: [educationEntryId], references: [id], onDelete: Cascade)

  @@index([admissionApplicationId])
  @@index([educationEntryId])
  @@map("admission_documents")
}

model AgentProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  agencyName String
  agencyCode String   @unique
  branchName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_profiles")
}

// ─── LIA PROFILES (PR-DOCUSIGN-1) ─────────────────────────────────────────────
// LIA's IAA (Immigration Advisers Authority) credential record. 1:1 with a
// User of role=LIA. Mirrors the AgentProfile shape — 1:1 child table on User,
// snake_case @@map, cascade on user delete.
//
// Lifecycle: an LIA logs in for the first time after this migration ships,
// sees a "Complete your profile" banner, enters their iaaLicenceNumber +
// uploads a licence cert PDF (multer pending → ./uploads/lia-licences/<userId>/
// <filename>.pdf). At that point iaaLicenceNumber + iaaLicenceFileUrl +
// the three file-metadata columns are populated, but iaaLicenceVerifiedAt +
// iaaLicenceVerifiedById stay null. An OWNER/ADMIN then manually cross-checks
// the cert against the IAA register and marks it verified. Only verified LIAs
// become eligible for auto-assign + contract-send (gate added in a later step).
//
// Every field nullable because a row may exist BEFORE the LIA submits anything.
// Service layer enforces "verified" = all of iaaLicenceNumber, iaaLicenceFileUrl,
// iaaLicenceVerifiedAt are non-null.
//
// Forward-compat: iaaLicenceExpiryDate, iaaLicenceClass, and similar columns
// land via additive migrations later. All would be nullable, no backfill needed.
model LiaProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique

  // Credential — populated when the LIA submits their profile.
  // @unique because IAA licence numbers are globally unique per natural
  // person in NZ. Postgres allows multiple NULLs in a unique index, so
  // "not uploaded yet" rows don't conflict.
  iaaLicenceNumber         String?   @unique

  // Licence cert PDF metadata. Same shape as case-documents, visa-supporting,
  // inz-receipts — filesystem path + denormalised size/mime/name so list views
  // don't need fs.stat. Stored under ./uploads/lia-licences/<userId>/<file>.pdf.
  iaaLicenceFileUrl        String?
  iaaLicenceFileName       String?
  iaaLicenceFileMime       String?
  iaaLicenceSizeBytes      Int?

  // Verification trail — written together by an OWNER/ADMIN after manual
  // cross-check against the IAA register. SetNull on verifier hard-delete:
  // timestamp survives as audit evidence, attribution is lost.
  iaaLicenceVerifiedAt     DateTime?
  iaaLicenceVerifiedById   String?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user        User  @relation("LiaProfileOwner",    fields: [userId],                 references: [id], onDelete: Cascade)
  verifiedBy  User? @relation("LiaProfileVerifier", fields: [iaaLicenceVerifiedById],  references: [id], onDelete: SetNull)

  @@map("lia_profiles")
}

// ─── VISA APPLICATION (INZ 1200) ──────────────────────────────────────────────
// One row per admission application. Grows section by section as the student
// works through the INZ 1200 form. All editable fields stay nullable so the
// student can save a partial draft; required-ness is enforced in the UI and
// at save-time. otherNames + nationalId are PII — encrypted via CryptoService
// using the same AES-256-GCM envelope as admission's PR-SEC3 columns.
model VisaApplication {
  id                      String   @id @default(cuid())
  applicationId           String   @unique

  // Section 1 — Identity Details
  hasMononym              Boolean?
  middleNames             String?
  hasUsedOtherNames       Boolean?
  otherNamesEncrypted     Bytes?
  countryWhenSubmitting   String?
  prevAppliedNzVisa       Boolean?
  prevRequestedNzeta      Boolean?
  everTravelledNz         Boolean?
  totalNzTime24Plus       Boolean?
  passportIssueDate       DateTime?
  passportExpiryDate      DateTime?
  passportCountryOfIssue  String?
  passportGender          String?
  stateOfBirth            String?
  cityOfBirth             String?
  hasNationalId           Boolean?
  nationalIdEncrypted     Bytes?
  nationalIdCountry       String?

  // Section 2 — Address and contact information (PR-VISA2)
  physicalStreetEncrypted     Bytes?
  physicalSuburb              String?
  physicalCity                String?
  physicalState               String?
  physicalPostcode            String?
  physicalCountry             String?
  postalSameAsPhysical        Boolean?
  postalStreetEncrypted       Bytes?
  postalSuburb                String?
  postalCity                  String?
  postalState                 String?
  postalPostcode              String?
  postalCountry               String?
  preferredContactCountryCode    String?
  preferredContactNumber         String?
  alternativeContactCountryCode  String?
  alternativeContactNumber       String?

  // Section 3 — Eligibility (PR-VISA3)
  // Study history
  holdsNzStudentVisa             Boolean?
  // Offer of Place assistance
  usedEducationAgent             Boolean?
  agentOrganisationName          String?
  agentCountry                   String?
  agentGivenName                 String?
  agentSurname                   String?
  agentEmail                     String?
  // Study details
  studyingSchoolLevel            Boolean?
  studyingMastersOrPhd           String?
  educationProviderName          String?
  studyLocation                  String?
  courseRequiresOtherLocation    Boolean?
  courseProgrammeName            String?
  courseStartDate                DateTime?
  courseEndDate                  DateTime?
  intendedArrivalDate            DateTime?
  // PhD details — only relevant when studyingMastersOrPhd = "PHD"
  phdDiscipline                  String?
  phdSubject                     String?
  phdSupervisorTitle             String?
  phdSupervisorGivenName         String?
  phdSupervisorSurname           String?
  phdSupervisorOrganisation      String?
  phdPublishedPapers             Boolean?
  phdSupervisorOutsideNz         Boolean?
  // Student identification number
  providerIssuedStudentId        Boolean?
  studentIdNumber                String?
  // Your situation and plans — six free-text fields are PII (AES-256-GCM)
  homeCommitmentsEncrypted       Bytes?
  studyRelatesToPrevious         Boolean?
  studyRelatesDetailsEncrypted   Bytes?
  whyStudyNzEncrypted            Bytes?
  whyThisProviderEncrypted       Bytes?
  howCourseBenefitsEncrypted     Bytes?
  plansAfterStudyEncrypted       Bytes?
  studyingMultiYear              Boolean?

  // Section 4 — Character (PR-VISA4)
  // Character details (4 mandatory Y/N declarations)
  everConvicted                  Boolean?
  underInvestigation             Boolean?
  everDeportedExcluded           Boolean?
  everRefusedVisa                Boolean?
  // Police certificate from the country of citizenship — the file itself
  // is uploaded via the admission documents pipeline with documentType =
  // VISA_POLICE_CERTIFICATE; these three columns capture the cert metadata.
  policeCertIssueDate            DateTime?
  policeCertCountryOfIssue       String?
  policeCertInEnglish            Boolean?
  // Other citizenships + 5+ years branch (no further inputs in this PR)
  holdsOtherCitizenships         Boolean?
  livedOtherCountry5Years        Boolean?

  // Section 5 — Health (PR-VISA5)
  hasTuberculosis                Boolean?
  needsRenalDialysis             Boolean?
  hasMedicalCondition            Boolean?
  needsResidentialCare           Boolean?
  isPregnant                     Boolean?
  intendedLengthOfStay           String?
  hadMedicalExam                 Boolean?
  medicalRefNumber               String?
  tbCountriesNoMore              Boolean?
  insuranceDeclarationAgreed     Boolean?
  publicHealthAckAgreed          Boolean?

  // Section 7 — Employment history (PR-VISA7)
  everGovernmentEmployed         Boolean?
  everPrisonGuard                Boolean?
  currentlyWorking               Boolean?
  hadPreviousEmployment          Boolean?
  everUnemployed                 Boolean?

  // Section 8 — Relationships (PR-VISA8)
  // Note: relationshipStatus + hasChildren are sourced read-only from
  // admission.maritalStatus + admission.hasChildren (see PR-VISA8 reuse
  // notes). Only the three Y/N gates that have no admission equivalent
  // live here.
  hasFormerPartners              Boolean?
  hasSiblings                    Boolean?
  hasNzContacts                  Boolean?

  // Section 9 — Background details (PR-VISA9). Flat set of Y/N
  // declarations; all nullable so partial drafts can save.
  heldReligiousCulturalPosition  Boolean?
  heldPoliticalAppointment       Boolean?
  hadPoliticalAssociation        Boolean?
  associatedIntelligenceAgency   Boolean?
  witnessedIllTreatment          Boolean?
  involvedArmedConflict          Boolean?
  associatedViolentGroup         Boolean?
  involvedWarCrimes              Boolean?
  memberLiberationMilitia        Boolean?
  everDetainedImprisoned         Boolean?

  // Section 10 — Military service (PR-VISA10). Three gating Y/Ns plus
  // a conditional explanation (only when D3 = true). exemptExplanation
  // is PII (free-text reason) and stored encrypted via CryptoService.
  militaryServiceCompulsoryHome  Boolean?
  everUndertakenMilitaryService  Boolean?
  wasExemptFromMilitaryService   Boolean?
  exemptExplanationEncrypted     Bytes?

  // Section 11 — Travel history (PR-VISA11). Single gate Y/N; when Yes
  // the repeating visa_travel_history_entries rows hold each trip
  // (destination / pointOfEntry / otherPurpose are free-text PII and
  // stored encrypted via CryptoService, same envelope as Section 10).
  hasTravelledInternationally    Boolean?

  // Section 12 — Immigration assistance (PR-VISA12). Single-instance
  // (no child table). Gate Y/N + capacity enum + a five-field adviser
  // block that only applies when capacity ∈ {LICENSED_IMMIGRATION_
  // ADVISER, EXEMPT_PERSON}. adviserNumber / adviserFullName /
  // adviserEmail / adviserContactNumber are all third-party PII and
  // stored encrypted via CryptoService (AES-256-GCM, same envelope as
  // Section 10 / 11). Server-side clearing: completingOnBehalf = false
  // OR capacity ∉ {ADVISER set} nulls every downstream field on save.
  completingOnBehalf             Boolean?
  immigrationAssistanceCapacity  ImmigrationAssistanceCapacity?
  adviserNumberEncrypted         Bytes?
  adviserFullNameEncrypted       Bytes?
  adviserEmailEncrypted          Bytes?
  adviserContactNumberEncrypted  Bytes?
  adviserIsPrimaryContact        Boolean?

  // Section 13 — Supporting documents page 1 (PR-VISA13). Three
  // parent-row fields plus a repeating visa_supporting_documents
  // child table (one row per documentType per application). The
  // actual file bytes are NEVER sent to or stored by the backend;
  // file storage is deferred to a later PR — we record only
  // originalFilename / mimeType / sizeBytes / uploadedAt as metadata.
  // countryOfResidence is free-text PII (identifying location) and
  // encrypted via CryptoService, same envelope as the Section 12
  // adviser fields. areAllDocsInEnglish is the "are all the documents
  // you intend to upload in English?" gate from the page-1 guidance
  // block.
  livingInDifferentCountry       Boolean?
  countryOfResidenceEncrypted    Bytes?
  areAllDocsInEnglish            Boolean?

  // Section 14 — Supporting documents page 2 (PR-VISA14). 28 parent
  // flags driving a tree of conditional sections plus three encrypted
  // free-text fields. The repeating "Other evidence" block lives in
  // its own child table (VisaOtherEvidenceEntry). All conditional
  // children are reconciled server-side on save — see
  // visa.service.saveSupportingDocuments2 for the cascade-clear
  // rules. File storage is still deferred; only metadata flows.
  tuitionFeesPaid                 Boolean?
  tuitionPaymentMethod            TuitionPaymentMethod?
  fundsSourceSavings              Boolean?
  fundsSourceNZSponsor            Boolean?
  fundsSourceInz1014              Boolean?
  fundsSourcePrepaidAccom         Boolean?
  fundsSourceScholarship          Boolean?
  outwardSourceSufficientFunds    Boolean?
  outwardSourceInz1014            Boolean?
  outwardSourcePrepaidBooking     Boolean?
  outwardSourceScholarship        Boolean?
  fundsFormatBankAccount          Boolean?
  fundsFormatProvidentFund        Boolean?
  fundsFormatEducationLoan        Boolean?
  fundsFormatFixedTermDeposit     Boolean?
  fundsFormatOther                Boolean?
  savingsSourceWages              Boolean?
  savingsSourceSelfEmployment     Boolean?
  savingsSourceRentalIncome       Boolean?
  savingsSourceOther              Boolean?
  depositExplanationEncrypted     Bytes?
  scholarshipNameEncrypted        Bytes?
  scholarshipOrganisationEncrypted Bytes?
  studyIs120CreditsOrMore         Boolean?
  courseRequiresPracticalWork     Boolean?
  tookEnglishTest                 Boolean?
  declarationChecked              Boolean?

  currentStep             Int      @default(1)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  admissionApplication    AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  otherCitizenships       VisaOtherCitizenship[]
  tbRiskCountries         VisaTbRiskCountry[]
  educationSupplements    VisaEducationSupplement[]
  employmentEntries       VisaEmploymentEntry[]
  unemploymentEntries     VisaUnemploymentEntry[]
  partner                 VisaPartner?
  formerPartners          VisaFormerPartner[]
  children                VisaChild[]
  parents                 VisaParent[]
  siblings                VisaSibling[]
  nzContacts              VisaNzContact[]
  militaryServices        VisaMilitaryService[]
  travelHistoryEntries    VisaTravelHistoryEntry[]
  supportingDocuments     VisaSupportingDocument[]
  otherEvidenceEntries    VisaOtherEvidenceEntry[]
  visaCase                VisaCase?

  @@map("visa_applications")
}

// Step 8 (PR-VISA8) — Relationships. Six new tables; all third-party
// name fields and passport numbers / phone numbers / street addresses
// are PII and stored encrypted (AES-256-GCM via CryptoService, same
// envelope as the earlier Visa Section PII columns).
//
// visa_partner is singleton (UNIQUE on visaApplicationId) — at most one
// current partner per visa application. Everything else is a repeating
// child table with sortOrder for stable render order. Cascade on the
// parent FK so the visa_application's delete tears everything down.

model VisaPartner {
  id                       String   @id @default(cuid())
  visaApplicationId        String   @unique
  relationshipToApplicant  String?
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  gender                   String?
  dateOfBirth              DateTime?
  relationshipStatus       String?
  countryOfBirth           String?
  stateOfBirth             String?
  cityOfBirth              String?
  nationality              String?
  countryOfResidence       String?
  occupation               String?
  holdsPassport            Boolean?
  passportNumberEncrypted  Bytes?
  passportCountryOfIssue   String?
  passportIssueDate        DateTime?
  passportExpiryDate       DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@map("visa_partner")
}

model VisaFormerPartner {
  id                    String   @id @default(cuid())
  visaApplicationId     String
  givenNameEncrypted    Bytes?
  middleNamesEncrypted  Bytes?
  surnameEncrypted      Bytes?
  gender                String?
  dateOfBirth           DateTime?
  relationshipStatus    String?
  countryOfBirth        String?
  nationality           String?
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  visaApplication       VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_former_partners")
}

model VisaChild {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  gender                   String?
  dateOfBirth              DateTime?
  countryOfBirth           String?
  nationality              String?
  relationshipToApplicant  String?
  livesWithApplicant       Boolean?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_children")
}

model VisaParent {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  relationshipToApplicant  String?
  isDeceased               Boolean?
  gender                   String?
  dateOfBirth              DateTime?
  dateOfBirthUnknown       Boolean?
  relationshipStatus       String?
  countryOfBirth           String?
  citizenship              String?
  countryOfResidence       String?
  occupation               String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_parents")
}

model VisaSibling {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  relationshipToApplicant  String?
  gender                   String?
  dateOfBirth              DateTime?
  dateOfBirthUnknown       Boolean?
  relationshipStatus       String?
  countryOfBirth           String?
  citizenship              String?
  countryOfResidence       String?
  occupation               String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_siblings")
}

model VisaNzContact {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  givenNameEncrypted       Bytes?
  middleNamesEncrypted     Bytes?
  surnameEncrypted         Bytes?
  relationshipToApplicant  String?
  phoneEncrypted           Bytes?
  email                    String?
  streetEncrypted          Bytes?
  suburb                   String?
  townCity                 String?
  region                   String?
  postcode                 String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_nz_contacts")
}

// Step 7 employment history (PR-VISA7). One table covers both the
// single CURRENT job and any number of PREVIOUS jobs — distinguished by
// entryKind. duties is PII (free-text role description) and stored
// encrypted via CryptoService using the standard AES-256-GCM envelope.
// startDate carries month-precision (we store the 1st of the month);
// endDate is null on the CURRENT row.
model VisaEmploymentEntry {
  id                   String   @id @default(cuid())
  visaApplicationId    String
  entryKind            String
  startDate            DateTime?
  endDate              DateTime?
  roleTitle            String?
  dutiesEncrypted      Bytes?
  countryOfWork        String?
  stateOfWork          String?
  supervisorName       String?
  organisationField    String?
  organisationCountry  String?
  organisationState    String?
  employerName         String?
  employerStreet       String?
  employerSuburb       String?
  employerTownCity     String?
  employerSubregion    String?
  employerRegion       String?
  employerPostcode     String?
  employerPhone        String?
  employerEmail        String?
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  visaApplication      VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_employment_entries")
}

// Step 7 unemployment / unpaid-service periods (PR-VISA7). Both
// free-text descriptions are PII and stored encrypted.
model VisaUnemploymentEntry {
  id                          String   @id @default(cuid())
  visaApplicationId           String
  startDate                   DateTime?
  endDate                     DateTime?
  activityEncrypted           Bytes?
  financialSupportEncrypted   Bytes?
  sortOrder                   Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  visaApplication             VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_unemployment_entries")
}

// Visa-side extras for an admission education entry (PR-VISA6). One row
// per admission_education_entry — the admission row holds the data INZ
// already collects via the admission form (qualification level, field of
// study, institution name, country, start/end YEAR, completed/awarded
// status). This supplement holds only what INZ Section 6 needs on top:
//   * startMonth / endMonth — admission stores year-only
//   * institutionState / institutionTown — admission has no address fields
//   * qualificationAwarded — distinct semantic from admission's
//     `completed` (student-finished) vs `certificateNotReceived` (cert in
//     transit). INZ asks specifically whether the institution conferred
//     the qualification.
// Cascade-deletes with either parent so a deleted admission entry never
// strands an orphan supplement.
model VisaEducationSupplement {
  id                    String   @id @default(cuid())
  visaApplicationId     String
  educationEntryId      String   @unique
  startMonth            Int?
  endMonth              Int?
  institutionState      String?
  institutionTown       String?
  qualificationAwarded  Boolean?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  visaApplication       VisaApplication         @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)
  educationEntry        AdmissionEducationEntry @relation(fields: [educationEntryId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_education_supplements")
}

// Repeating rows for the TB-risk countries block (PR-VISA5). One row per
// country the student has visited or lived in over the last 5 years.
// Same shape as VisaOtherCitizenship — live-API per row (POST/PATCH/DELETE
// endpoints), cascade-deleted with the parent visa application.
model VisaTbRiskCountry {
  id                String   @id @default(cuid())
  visaApplicationId String
  country           String
  totalDurationDays Int
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  visaApplication   VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_tb_risk_countries")
}

// Step 10 military service declarations (PR-VISA10). One row per
// service period — INZ Section D's D4 repeating block. duties is PII
// (free-text role description) and stored encrypted via CryptoService.
// dateStarted/dateFinished carry day precision (INZ wants full dates,
// not month-year). Replace-on-save: visa.service.ts wipes the array
// with deleteMany before reinserting on every Step 10 PATCH.
model VisaMilitaryService {
  id                 String   @id @default(cuid())
  visaApplicationId  String
  dateStarted        DateTime?
  dateFinished       DateTime?
  location           String?
  corps              String?
  division           String?
  brigade            String?
  battalion          String?
  unit               String?
  rank               String?
  dutiesEncrypted    Bytes?
  commandingOfficer  String?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  visaApplication    VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_military_services")
}

// Mode of arrival for a Section 11 travel-history entry (PR-VISA11).
// INZ 1200 lists Air / Sea / Land — encoded directly to avoid any
// free-text drift on this dropdown.
enum VisaArrivalMode {
  AIR
  SEA
  LAND
}

// Purpose of the trip for a Section 11 entry (PR-VISA11). Same INZ
// dropdown; OTHER unlocks the free-text otherPurpose column on the row.
enum VisaPurposeOfTravel {
  EDUCATION
  TOURISM
  BUSINESS
  FAMILY
  MEDICAL
  TRANSIT
  WORK
  OTHER
}

// Capacity in which a third party is completing the visa form on
// behalf of the applicant (PR-VISA12). Only LICENSED_IMMIGRATION_
// ADVISER and EXEMPT_PERSON unlock the five-field adviser block —
// the other three capacities (FAMILY_MEMBER, FRIEND, OTHER) only
// need the gate flag + capacity selection.
enum ImmigrationAssistanceCapacity {
  LICENSED_IMMIGRATION_ADVISER
  EXEMPT_PERSON
  FAMILY_MEMBER
  FRIEND
  OTHER
}

// Supporting document types (PR-VISA13). Page 1 of INZ's "Supporting
// documents" introduces the first six values; PR-VISA14 (page 2)
// will reuse this same enum and add more values for the page-2
// document categories. The UNIQUE constraint on
// (visaApplicationId, documentType) in VisaSupportingDocument means
// each application can only have one metadata row per type at a
// time — re-uploading replaces the existing row in a single
// transaction.
enum VisaSupportingDocumentType {
  PASSPORT
  NATIONAL_ID
  RESIDENCE_VISA
  MILITARY_RECORD
  TRAVEL_HISTORY
  AUTHORITY_DOC
  // PR-VISA14 (page 2) additions. The enum is shared between page 1
  // and page 2 because the metadata table is keyed on
  // (visaApplicationId, documentType) and one unique constraint
  // covers both pages cleanly.
  OFFER_OF_PLACE
  PHD_RESEARCH_PROPOSAL
  PUBLICATIONS_LIST
  PERSONAL_CIRCUMSTANCES_EVIDENCE
  PREVIOUS_TERTIARY_EVIDENCE
  CURRENT_EMPLOYMENT_EVIDENCE
  PREVIOUS_EMPLOYMENT_EVIDENCE
  ENGLISH_TEST_RESULTS
  TUITION_PAYMENT_CONFIRMATION
  INZ1014_FINANCIAL_UNDERTAKING
  PREPAID_ACCOMMODATION_EVIDENCE
  SCHOLARSHIP_EVIDENCE
  OUTWARD_TRAVEL_EVIDENCE
  BANK_STATEMENTS
  EMPLOYMENT_INCOME_EVIDENCE
  SCHEDULED_HOLIDAY_EVIDENCE
  OTHER_EVIDENCE
}

// PR-VISA14 (page 2 — Tuition fees section). The four ways a student
// can have arranged to pay tuition: self / partner-provider-or-loan /
// third-party sponsor / scholarship. Only relevant when
// tuitionFeesPaid = false; if fees are already paid we don't ask how.
enum TuitionPaymentMethod {
  SELF_PAID
  PARTNER_PROVIDER_OR_GOVT_LOAN
  THIRD_PARTY_SPONSOR
  SCHOLARSHIP
}

// PR-VISA14 (page 2 — "Other evidence" repeating block). Five
// categories the applicant can attach extra evidence rows under;
// OTHER unlocks the free-text customLabel column on the child row.
enum OtherEvidenceType {
  COVER_LETTER
  STATEMENT_OF_PURPOSE
  ADDITIONAL_FUNDS_EVIDENCE
  FAMILY_TIES_EVIDENCE
  OTHER
}

// Step 13 (PR-VISA13) — Supporting documents page 1 metadata row.
// File storage is deferred to a later PR; this table stores ONLY
// the metadata extracted from the File object in the browser
// (originalFilename / mimeType / sizeBytes). The bytes themselves
// never reach the backend.
//
// originalFilename is the user's chosen filename — not encrypted
// (it's a label, not personally identifying on its own). mimeType
// and sizeBytes are technical fields. uploadedAt records when the
// metadata row was created — distinct from createdAt because we'll
// eventually want to know "when did the user originally pick this
// file?" separately from row-creation timestamps after PR-14
// introduces actual storage.
//
// UNIQUE (visaApplicationId, documentType): enforces one row per
// type per application — replace-on-upload (service deletes the
// existing row by composite key before inserting the new one).
// PR-FILES-2 — represents a per-application requirement of this
// documentType. Files live in the visa_supporting_document_files
// child. The UNIQUE(visaApplicationId, documentType) survives — still
// one requirement per type per application. fulfilmentMessages
// continues to point at the parent (fulfilling a doc request means
// "you've provided >=1 file for this type", not "you provided THIS
// specific file"), so pre-existing CaseMessage FKs keep working.
model VisaSupportingDocument {
  id                 String                     @id @default(cuid())
  visaApplicationId  String
  documentType       VisaSupportingDocumentType
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  visaApplication    VisaApplication            @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)
  files              VisaSupportingDocumentFile[]
  // PR-LIA-4: CaseMessage DOCUMENT_REQUEST rows that the client
  // fulfilled by linking THIS supporting-document row.
  fulfilmentMessages CaseMessage[]              @relation("CaseMessageFulfilment")

  @@unique([visaApplicationId, documentType])
  @@index([visaApplicationId])
  @@map("visa_supporting_documents")
}

// PR-FILES-2 — per-entry classification (evidenceType + optional
// encrypted label). Files move to visa_other_evidence_entry_files.
model VisaOtherEvidenceEntry {
  id                    String            @id @default(cuid())
  visaApplicationId     String
  evidenceType          OtherEvidenceType
  customLabelEncrypted  Bytes?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  visaApplication       VisaApplication   @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)
  files                 VisaOtherEvidenceFile[]

  @@index([visaApplicationId])
  @@map("visa_other_evidence_entries")
}

// PR-FILES-2 — one row per uploaded file under a parent requirement.
// fileUrl is NOT NULL: a row in this table only exists when the bytes
// are on disk. createdAt is identical to uploadedAt for any row this
// service produces, but kept separate so a future audit/restore flow
// can distinguish "when did the file land in storage" from "when was
// this row written".
model VisaSupportingDocumentFile {
  id                       String   @id @default(cuid())
  visaSupportingDocumentId String
  originalFilename         String
  mimeType                 String
  sizeBytes                Int
  fileUrl                  String
  uploadedAt               DateTime @default(now())
  createdAt                DateTime @default(now())

  document                 VisaSupportingDocument @relation(fields: [visaSupportingDocumentId], references: [id], onDelete: Cascade)

  @@index([visaSupportingDocumentId])
  @@map("visa_supporting_document_files")
}

// PR-FILES-2 — one row per uploaded file under an other-evidence
// entry. Same shape as VisaSupportingDocumentFile.
model VisaOtherEvidenceFile {
  id                       String   @id @default(cuid())
  visaOtherEvidenceEntryId String
  originalFilename         String
  mimeType                 String
  sizeBytes                Int
  fileUrl                  String
  uploadedAt               DateTime @default(now())
  createdAt                DateTime @default(now())

  entry                    VisaOtherEvidenceEntry @relation(fields: [visaOtherEvidenceEntryId], references: [id], onDelete: Cascade)

  @@index([visaOtherEvidenceEntryId])
  @@map("visa_other_evidence_entry_files")
}

// PR-DASH-1 — Client-dashboard workflow status.
//
// The existing `Case` model (line 639) is a CRM/sales-side artifact
// keyed to Lead, with a `CaseStage` enum (ADMISSION / VISA / etc.) and
// a free-text `status`. VisaCase is a separate, dashboard-side row
// keyed to VisaApplication 1:1, with a structured status enum the
// client UI renders. They coexist by design — the CRM Case tracks the
// consultant's pipeline; the VisaCase tracks the student-facing visa
// workflow status.
//
// Auto-created on first dashboard load alongside the VisaApplication
// and AssessmentReport rows (single transaction, idempotent upsert by
// clientId / visaApplicationId).
enum VisaCaseStatus {
  DRAFT
  SUBMITTED_FOR_REVIEW
  REVIEWED
  READY_FOR_INZ
  INZ_SUBMITTED
  APPROVED
  DECLINED
}

model VisaCase {
  id                    String          @id @default(cuid())
  visaApplicationId     String          @unique
  clientId              String
  assignedConsultantId  String?
  status                VisaCaseStatus  @default(DRAFT)
  statusChangedAt       DateTime        @default(now())
  // userId of whoever changed status; null when system-set on creation.
  statusChangedBy       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  visaApplication       VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)
  client                User            @relation("VisaCaseClient", fields: [clientId], references: [id], onDelete: Cascade)
  assignedConsultant    User?           @relation("VisaCaseConsultant", fields: [assignedConsultantId], references: [id])

  // PR-DASH-2 children
  supportTickets        VisaSupportTicket[]
  fileNotes             VisaCaseFileNote[]

  // PR-CONSULT-1: per-role staff assignments. A case can have at
  // most one active assignment per VisaCaseRoleSlot at any time;
  // historical assignments stay on the row with unassignedAt set.
  assignments           VisaCaseAssignment[]

  @@index([clientId])
  @@index([assignedConsultantId])
  @@index([status])
  @@map("visa_cases")
}

// PR-DASH-1 — Friday AI scoring bot writeback target. Empty (all
// fields nullable) until the Wix pipe is wired and the bot posts a
// real report. summaryNarrative is free-text PII (the model's prose
// commentary) and stored encrypted via CryptoService (AES-256-GCM,
// same envelope as the visa-section encrypted columns).
model AssessmentReport {
  id                          String   @id @default(cuid())
  clientId                    String   @unique
  score                       Int?
  band                        Int?
  route                       String?
  summaryNarrativeEncrypted   Bytes?
  // Free-form JSON the AI bot returns alongside the narrative.
  aiRecommendations           Json?
  // Wix submission id once the lead-capture pipe is wired.
  sourceSubmissionId          String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  client                      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("assessment_reports")
}

// ─── PR-DASH-2 — Client-side support tickets + case file notes ───────
//
// Three new tables + five enums. Tickets are 1-N off the dashboard's
// VisaCase row (not the CRM-side Case at line 639 — that's the
// consultant pipeline artifact). Messages are 1-N off a ticket and
// store an encrypted free-text body. File notes are an append-only
// log of significant events that affect the case (ticket creation,
// status changes — and in later PRs, meeting transcripts and
// consultant notes).
//
// Body / subject / summary text is ALWAYS encrypted via CryptoService
// (AES-256-GCM), same envelope as every other PII column in the
// project.

// What part of Sorena the ticket is about. Drives badge colour on
// the client UI and (in a future PR) routes the inbox a staff
// member sees.
enum VisaTicketDepartment {
  ADMISSIONS
  VISA_APPLICATION
  DOCUMENTS
  PAYMENTS_FINANCE
  TECHNICAL_SUPPORT
  GENERAL_INQUIRY
}

// Workflow status. CLOSED is terminal — clients can't reopen; they
// open a new ticket if they need further help (per spec).
enum VisaTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VisaTicketPriority {
  LOW
  NORMAL
  HIGH
}

// Who wrote a given message row. SYSTEM is reserved for the service-
// generated rows (e.g. "Status changed from OPEN to RESOLVED") so
// the UI can render them as gray italic banners rather than chat
// bubbles.
enum VisaTicketMessageAuthorRole {
  CLIENT
  STAFF
  SYSTEM
}

// Kind of event the file note records. TICKET / SYSTEM_EVENT are
// emitted by this PR; MEETING_TRANSCRIPT and CONSULTANT_NOTE are
// reserved for PR-DASH-3.
enum VisaCaseFileNoteType {
  TICKET
  MEETING_TRANSCRIPT
  CONSULTANT_NOTE
  SYSTEM_EVENT
}

// One ticket per client question. subjectEncrypted is the only PII
// column on the row; all timestamps + foreign keys are cleartext for
// indexable filtering. assignedStaffId nulls out on staff deletion
// rather than cascading the ticket itself (a deleted consultant
// shouldn't tear down the client's ticket history).
model VisaSupportTicket {
  id                    String                @id @default(uuid())
  clientId              String
  caseId                String
  assignedStaffId       String?
  department            VisaTicketDepartment
  subjectEncrypted      Bytes
  status                VisaTicketStatus      @default(OPEN)
  priority              VisaTicketPriority    @default(NORMAL)
  lastClientMessageAt   DateTime?
  lastStaffMessageAt    DateTime?
  resolvedAt            DateTime?
  closedAt              DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  client                User                  @relation("VisaSupportTicketClient", fields: [clientId], references: [id], onDelete: Cascade)
  assignedStaff         User?                 @relation("VisaSupportTicketStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  case                  VisaCase              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  messages              VisaSupportTicketMessage[]

  // PR-DASH-4: chat messages that escalated INTO this ticket. One
  // ticket can have at most one origin chat message (the escalation
  // event); the relation is plural because the FK column lives on
  // the message side and Prisma needs the reverse list.
  chatEscalations       VisaChatMessage[]      @relation("ChatEscalations")

  @@index([clientId, status])
  @@index([assignedStaffId, status])
  @@index([caseId])
  @@map("visa_support_tickets")
}

// One row per message in a thread. isInternalNote is reserved for
// staff-side internal commentary in a future PR — this PR's client
// endpoints filter it out. The author FK uses a non-named relation
// because messages are not user-deletable.
model VisaSupportTicketMessage {
  id              String                          @id @default(uuid())
  ticketId        String
  authorId        String
  authorRole      VisaTicketMessageAuthorRole
  bodyEncrypted   Bytes
  isInternalNote  Boolean                         @default(false)
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt

  ticket          VisaSupportTicket               @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author          User                            @relation(fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
  @@map("visa_support_ticket_messages")
}

// Append-only log of events that affect the case. Acts as the
// consultant's "case file" — a single chronological view they can
// scroll through to catch up. summaryEncrypted holds a short
// human-readable string (e.g. "Ticket opened — DOCUMENTS: 'Scholarship
// question'"). createdById is nullable for system-emitted notes.
model VisaCaseFileNote {
  id                String                @id @default(uuid())
  caseId            String
  noteType          VisaCaseFileNoteType
  // Uuid of the source row (ticket id / meeting id / etc). Not a
  // typed FK because the source table varies by noteType.
  referenceId       String
  summaryEncrypted  Bytes
  createdById       String?
  createdAt         DateTime              @default(now())

  case              VisaCase              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy         User?                 @relation("VisaCaseFileNoteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([referenceId])
  @@map("visa_case_file_notes")
}

// ─── PR-DASH-3 — Meetings + transcripts (metadata + consultant notes) ─
//
// One row per consultation between a student and a consultant. Both
// sides have their own UI surfaces — students see read-only detail
// of their own meetings; consultants create/edit/cancel/complete and
// attach transcript metadata + write transcript notes after the
// session.
//
// PII columns encrypted via CryptoService (AES-256-GCM, same envelope
// as every other free-text PII column in the project):
//   * locationOrLink   — Zoom URL / office address / etc.
//   * agenda           — consultant-authored pre-meeting agenda
//   * transcriptNotes  — consultant-authored post-meeting notes
//
// cancelledReason is stored cleartext per the spec — it's a short
// admin-facing label rather than a freely-typed PII field.
//
// wixBookingId is NOT included here — the spec intentionally keeps
// the meeting row decoupled from any external booking platform.
// Booking is handled out-of-band via the WIX_BOOKING_URL env var
// surfaced through the existing /students/me/booking-config endpoint.
enum VisaMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum VisaMeetingType {
  CONSULTATION
  FOLLOW_UP
  DOCUMENT_REVIEW
  ASSESSMENT
}

model VisaMeeting {
  id                  String              @id @default(cuid())
  studentId           String
  consultantId        String?
  scheduledAt         DateTime
  durationMinutes     Int                 @default(30)
  status              VisaMeetingStatus   @default(SCHEDULED)
  meetingType         VisaMeetingType     @default(CONSULTATION)
  // Encrypted free-text PII (location / Zoom URL / agenda / post-meeting notes).
  locationOrLink      String?
  agenda              String?
  transcriptNotes     String?
  cancelledAt         DateTime?
  cancelledReason     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  student             User                @relation("StudentMeetings", fields: [studentId], references: [id])
  consultant          User?               @relation("ConsultantMeetings", fields: [consultantId], references: [id])
  transcriptFile      VisaMeetingTranscript?

  @@index([studentId, scheduledAt])
  @@index([consultantId, scheduledAt])
  @@index([status])
  @@map("visa_meetings")
}

// Transcript metadata. 1:1 with VisaMeeting (UNIQUE on meetingId).
// File bytes never reach the backend — see PR-13/PR-14 metadata-only
// pattern. PR-15 will attach the storage layer; this row stays the
// stable anchor.
model VisaMeetingTranscript {
  id                String      @id @default(cuid())
  meetingId         String      @unique
  originalFilename  String
  mimeType          String
  sizeBytes         Int
  uploadedById      String
  uploadedAt        DateTime    @default(now())

  meeting           VisaMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uploadedBy        User        @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@map("visa_meeting_transcripts")
}

// ─── PR-DASH-4 — In-platform AI chatbot (student-side, Pattern 1) ─────
//
// One conversation per student "thread". Messages are 1-N off the
// conversation. The chatbot is powered by Anthropic Claude Haiku;
// when the assistant detects it can't safely answer (sentinel token
// in its reply), the message is flagged for ESCALATION — the
// student then explicitly accepts or declines, and on accept a real
// VisaSupportTicket (PR-DASH-2) is created and linked back to the
// originating assistant message via escalatedTicketId.
//
// PII handling:
//   * VisaChatConversation.title  — encrypted (first user message,
//     truncated to 80 chars).
//   * VisaChatMessage.content     — encrypted, both user and assistant
//     messages. Cleartext is only held in memory long enough to send
//     to / receive from Anthropic, never logged.
//
// We don't store any of Anthropic's response metadata (request_id,
// stop_reason, etc.) other than the model name + token counts, to
// keep our row narrow and the audit trail clean.

enum VisaChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model VisaChatConversation {
  id          String              @id @default(cuid())
  studentId   String
  // Encrypted base64 (CryptoService). First user message truncated
  // to 80 chars after trim — only used as a list-row label.
  title       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  archivedAt  DateTime?

  student     User                @relation("StudentChatConversations", fields: [studentId], references: [id])
  messages    VisaChatMessage[]

  @@index([studentId, updatedAt])
  @@map("visa_chat_conversations")
}

model VisaChatMessage {
  id                  String                  @id @default(cuid())
  conversationId      String
  role                VisaChatMessageRole
  // Encrypted base64 (CryptoService). Cleartext only ever passes
  // through the service layer to the model and back.
  content             String
  tokensIn            Int?
  tokensOut           Int?
  // Model identifier string (e.g. "claude-haiku-4-5-20251001").
  // Stored so future migrations across model versions can be audited.
  modelUsed           String?
  escalationOffered   Boolean                 @default(false)
  // Set when the student accepted escalation; FK to the resulting
  // support ticket so we can render a "Linked to ticket #..." badge
  // in the chat thread.
  escalatedTicketId   String?
  createdAt           DateTime                @default(now())

  conversation        VisaChatConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  escalatedTicket     VisaSupportTicket?      @relation("ChatEscalations", fields: [escalatedTicketId], references: [id])

  @@index([conversationId, createdAt])
  @@map("visa_chat_messages")
}


// Step 11 (PR-VISA11) — Travel history child row. The gate flag
// hasTravelledInternationally lives on the parent visa_application;
// when Yes the student adds one entry per trip taken in the last 5
// years (excluding NZ). Month + year are stored as Ints rather than
// a DateTime because INZ collects month-precision and a synthetic
// day-1 timestamp would be a footgun for downstream date math.
//
// destinationEncrypted / pointOfEntryEncrypted / otherPurposeEncrypted
// are the only PII columns — country names + ports of entry can
// re-identify a student against open border crossing records, and
// otherPurpose is free-text. Same AES-256-GCM envelope as Section 10.
//
// Replace-on-save: visa.service.saveTravelHistory wipes the array
// with deleteMany before reinserting on every Step 11 PATCH, matching
// the Step 10 transactional pattern.
model VisaTravelHistoryEntry {
  id                       String   @id @default(cuid())
  visaApplicationId        String
  destinationEncrypted     Bytes?
  dateEnteredMonth         Int?
  dateEnteredYear          Int?
  dateExitedMonth          Int?
  dateExitedYear           Int?
  arrivalMode              VisaArrivalMode?
  pointOfEntryEncrypted    Bytes?
  purposeOfTravel          VisaPurposeOfTravel?
  otherPurposeEncrypted    Bytes?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  visaApplication          VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_travel_history_entries")
}

// Repeating rows for "Do you hold any other citizenships?" = Yes
// (PR-VISA4 fix). Mirrors the admission_education_entries pattern: each
// row is mutated via its own POST/PATCH/DELETE endpoint, the rows are
// returned alongside the parent application on GET, and they cascade
// delete when the parent visa_application is removed. When the student
// toggles holdsOtherCitizenships back to false on save, the service
// deletes every row atomically — no orphans.
model VisaOtherCitizenship {
  id                String   @id @default(cuid())
  visaApplicationId String
  country           String
  holdsPassport     Boolean
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  visaApplication   VisaApplication @relation(fields: [visaApplicationId], references: [id], onDelete: Cascade)

  @@index([visaApplicationId])
  @@map("visa_other_citizenships")
}

// ─── PR-CONSULT-1 — Staff roles + assignments + owner approval ────────
//
// Foundation for the consultant-side platform. No consultant UI yet
// (lands in PR-CONSULT-2); this PR introduces the schema, services,
// guards, and approval queue that the UI will plug into.
//
// Encryption: OwnerApprovalRequest.payload / reason / decisionNote
// and PlatformSetting.value are stored as base64-encoded AES-256-GCM
// ciphertext in TEXT columns (CryptoService at the boundary — same
// envelope as PR-DASH-3/PR-DASH-4 free-text PII).

// Functional staff slot on a VisaCase. A case can have at most one
// active assignment per slot at any time; reassigning closes the
// prior row (sets unassignedAt) and inserts a new row.
enum VisaCaseRoleSlot {
  LIA
  CONSULTANT
  SUPPORT
  FINANCE
}

// Lifecycle for an owner-approval request. EXPIRED is set lazily on
// read (on-read sweep — no scheduler needed for launch). EXECUTED /
// EXECUTION_FAILED record whether the underlying action actually ran
// after OWNER approval.
enum OwnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  EXECUTED
  EXECUTION_FAILED
}

// Set of destructive / sensitive actions that SUPER_ADMIN cannot
// execute directly — they enqueue an OwnerApprovalRequest instead.
// ADMIN cannot perform these actions at all (rejected with 403 at
// the controller).
enum OwnerApprovalActionType {
  CREATE_STAFF_USER
  CHANGE_STAFF_ROLE
  DEACTIVATE_STAFF
  DELETE_CASE
  DELETE_STUDENT
  ISSUE_REFUND
  CHANGE_PLATFORM_SETTING
  // PR-CONSULT-4: permanent staff user deletion. OWNER inline,
  // SUPER_ADMIN routes through this approval queue.
  HARD_DELETE_STAFF
}

model VisaCaseAssignment {
  id             String           @id @default(cuid())
  caseId         String
  staffId        String
  roleSlot       VisaCaseRoleSlot
  assignedAt     DateTime         @default(now())
  assignedById   String
  // unassignedAt IS NULL means the row is the currently-active
  // assignment for (caseId, roleSlot). Filtering on this is the
  // primary index access pattern; the composite index below
  // optimises for it.
  unassignedAt   DateTime?
  unassignedById String?

  case           VisaCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  staff          User             @relation("StaffAssignments", fields: [staffId], references: [id])
  assignedBy     User             @relation("AssignmentsMade", fields: [assignedById], references: [id])

  @@index([caseId, roleSlot, unassignedAt])
  @@index([staffId, unassignedAt])
  @@map("visa_case_assignments")
}

model OwnerApprovalRequest {
  id              String                   @id @default(cuid())
  requestedById   String
  actionType      OwnerApprovalActionType
  // Encrypted JSON payload describing the action precisely (e.g.
  // { userId, newRole } for CHANGE_STAFF_ROLE). Stored as base64
  // ciphertext in a TEXT column.
  payload         String
  reason          String?
  status          OwnerApprovalStatus      @default(PENDING)
  decidedById     String?
  decidedAt       DateTime?
  decisionNote    String?
  // 7 days from creation; expires lazily on read.
  expiresAt       DateTime
  executedAt      DateTime?
  executionError  String?

  requestedBy     User                     @relation("OwnerApprovalRequester", fields: [requestedById], references: [id])
  decidedBy       User?                    @relation("OwnerApprovalDecider", fields: [decidedById], references: [id])

  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([status, expiresAt])
  @@index([requestedById, createdAt])
  @@map("owner_approval_requests")
}

// Soft-disable flag for staff users — avoids deleting historical
// data. 1:1 with User (UNIQUE userId via @id).
model StaffActiveStatus {
  userId           String    @id
  isActive         Boolean   @default(true)
  deactivatedAt    DateTime?
  deactivatedById  String?

  user             User      @relation("StaffActive", fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_active_status")
}

// Stripe-issued card refunds (real money out). PR-CARD-REFUND wires
// stripe.refunds.create against the original PaymentIntent for the
// exceptional cash-out cases (legal / service-not-provided).
//   status: PENDING (Stripe accepted, async) → COMPLETED (succeeded) /
//   FAILED. The legacy PENDING_STRIPE_INTEGRATION value predates the
//   wiring (dormant owner-approval executor) and is excluded from the
//   "one live refund per payment" guard.
//   paymentId references Payment.id; consultationId links the booking
//   for the wallet-exclusivity check + staff UI.
model Refund {
  id             String   @id @default(cuid())
  paymentId      String
  consultationId String?
  amountCents    Int
  reason         String?
  status         String   @default("PENDING_STRIPE_INTEGRATION")
  stripeRefundId String?  @unique
  createdAt      DateTime @default(now())
  createdById    String

  @@index([paymentId])
  @@map("refunds")
}

// PR-SCORECARD-4 — Generic key-value store for platform-wide settings.
//
// Two coexisting conventions live in this table:
//
//   * Legacy (owner-approval queue): `value` is AES-256-GCM ciphertext
//     via CryptoService.enc(). Reads must decrypt. Keys are arbitrary
//     OWNER-approved settings (CHANGE_PLATFORM_SETTING executor).
//   * PR-SCORECARD-4 (booking_urls + wix_integration categories):
//     `value` is plaintext. `category` is `booking_urls` |
//     `wix_integration` | `general`. PlatformSettingsService writes
//     these. The WIX_WEBHOOK_SECRET value is never returned plaintext
//     by the API except at regeneration time (masked as ●●●●●●●● in
//     every other response and in audit rows).
//
// `id` is the PK so each setting has a stable identifier; `key` is
// the unique business identifier used by callers (BOOKING_URL_FREE_15MIN,
// WIX_WEBHOOK_SECRET, etc.).
model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.Text
  category    String   @default("general") @db.VarChar(50)
  updatedById String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  updatedBy   User     @relation("PlatformSettingUpdater", fields: [updatedById], references: [id])

  @@index([category])
  @@map("platform_settings")
}

// ─── SCORECARD (PR-SCORECARD-1) ──────────────────────────────────────
//
// One row per submission of the 100-point Readiness Assessment. A
// user can submit multiple times — every row is preserved so we can
// see how they improved (e.g. retook after an IELTS upgrade).
//
// `answersEncrypted` carries the raw answers JSON via the
// CryptoService AES-256-GCM envelope. Answers contain DOB, financial
// info, refusal history — everything that lands on a row here is PII.
//
// Computed columns (totalScore, category*Score, band, hardStops,
// riskFlags, gateResults, executionEligible, nextAction) are derived
// from `answers` by the TypeScript port of sorena_scoring.py. Storing
// them denormalised here is the deliberate choice — the engine is
// the source of truth at submit time; re-running it later on a stored
// answers payload should reproduce the same numbers, but we don't
// want to re-decrypt + re-score on every staff view.
//
// `leadId` 1:0..1 — set after the auto-created Lead row lands in the
// CRM in the same transaction as the submission. The unique constraint
// enforces "one Lead per submission" so re-submissions don't pile
// onto the same Lead row.
enum ScorecardBand {
  BAND_1
  BAND_2
  BAND_3
  BAND_4
  BAND_5
  BAND_6
}

enum ScorecardNextAction {
  NURTURE_ONLY
  PAY_GAP_CLOSING_SESSION
  BOOK_FREE_15MIN_SESSION
  BLOCKED_HARD_STOP
}

model ScorecardSubmission {
  id                   String              @id @default(uuid())
  userId               String
  answersEncrypted     Bytes
  // Computed scores. All Int-typed scoring columns become nullable
  // in PR-SCORECARD-2 because draft rows exist before scoring runs
  // — but at the Prisma level we keep them NOT NULL with sentinel
  // 0 defaults for drafts (set in saveDraft). Reasoning: changing
  // their nullability now would force a backfill on every legacy
  // submitted row, and the engine output is always populated when
  // isDraft=false. The frontend never reads scores while isDraft=true.
  totalScore           Int
  category1Score       Int
  category2Score       Int
  category3Score       Int
  category4Score       Int
  band                 ScorecardBand
  // Hard stops (structured JSON, plaintext — these are categorical,
  // not PII). riskFlags is a string[] for the same reason.
  hardStops            Json
  riskFlags            String[]            @default([])
  // 5-gate execution check
  executionEligible    Boolean
  gateResults          Json
  // Routing
  nextAction           ScorecardNextAction
  nextActionTextEn     String              @db.Text
  nextActionTextFa     String              @db.Text
  // Polish PR (post-e57a769): structured next-action payload
  // (heading + bullets + optional leadIn). Nullable so legacy rows
  // submitted before this column existed still load; the frontend
  // falls back to nextActionTextEn when this is null.
  nextActionContent    Json?
  // PR-SCORECARD-2: autosave / draft state.
  //   * `isDraft=true`  — row is the user's in-progress questionnaire.
  //                       Scoring columns hold sentinel zeros / BAND_1
  //                       / NURTURE_ONLY; never trust them. submittedAt
  //                       is also unreliable in draft state (re-used as
  //                       a "created at" timestamp).
  //   * `isDraft=false` — row is a real submission. Scoring columns
  //                       are populated, leadId is set, audit rows
  //                       fired. Legacy rows from PR-SCORECARD-1 are
  //                       backfilled `isDraft=false` by the migration.
  // `draftLastSavedAt` tracks the last autosave so the form can
  // render "Last saved 2 minutes ago" if we choose to surface it.
  isDraft              Boolean             @default(false)
  draftLastSavedAt     DateTime?
  // Lifecycle
  submittedAt          DateTime            @default(now())
  leadId               String?             @unique
  consultationBookedAt DateTime?
  // Audit (request-side context; the user-side audit row is in audit_logs)
  ipAddress            String?             @db.VarChar(64)
  userAgent            String?             @db.Text

  user                 User                @relation("ScorecardUser", fields: [userId], references: [id], onDelete: Cascade)
  lead                 Lead?               @relation("ScorecardLead", fields: [leadId], references: [id])

  @@index([userId, submittedAt])
  @@index([band, submittedAt])
  @@index([executionEligible])
  // PR-SCORECARD-2: fast "get my open draft" lookup. Composite
  // (userId, isDraft) keeps the index narrow — most rows are
  // submitted (false), only the in-flight draft per user is true.
  @@index([userId, isDraft])
  @@map("scorecard_submissions")
}

// ─── MARKETING / AFFILIATE LINK TRACKING (PR-SCORECARD-2) ────────────
//
// Three-table cluster for attribution of leads to marketing channels
// and (optionally) named affiliate agents. Commission percentages and
// payout workflow are deliberately deferred to PR-AFFILIATE-1 — this
// PR's job is to capture WHO brought the lead in, not how much they
// get paid.
//
// `AffiliateAgent`        — a named human/partner who refers leads.
//                           Email/phone optional (some referrers are
//                           influencer accounts, not contactable people).
// `TrackingLink`          — one short URL per (channel, agent?, campaign?)
//                           combo. Each click increments `clickCount`
//                           AND writes a `TrackingLinkClick` row for
//                           per-click forensics. `agentId` is NULL for
//                           pure marketing-channel links (no affiliate).
// `TrackingLinkClick`     — one row per click. Captures ip / ua / referer
//                           so we can spot bot floods or audit
//                           inflated conversion counts.
//
// First-attribution-wins is enforced in code (Lead row's tracking columns
// are set only when null), not at the DB level — the spec is explicit
// that the channel that brought a lead in keeps the credit.
enum MarketingChannelType {
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  TWITTER
  WHATSAPP
  EMAIL
  WIX_HOMEPAGE
  TELEGRAM
  TIKTOK
  FACEBOOK
  DIRECT
  OTHER
}

enum AffiliateAgentStatus {
  ACTIVE
  PAUSED
  TERMINATED
}

enum TrackingLinkStatus {
  ACTIVE
  ARCHIVED
}

model AffiliateAgent {
  id              String                @id @default(uuid())
  fullName        String                @db.VarChar(200)
  email           String?               @db.VarChar(200)
  phone           String?               @db.VarChar(64)
  status          AffiliateAgentStatus  @default(ACTIVE)
  notes           String?               @db.Text
  createdById     String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  createdBy       User                  @relation("AffiliateAgentCreator", fields: [createdById], references: [id])
  trackingLinks   TrackingLink[]
  attributedLeads Lead[]                @relation("LeadAttributedAgent")

  @@index([status, fullName])
  @@map("affiliate_agents")
}

model TrackingLink {
  id              String                @id @default(uuid())
  shortCode       String                @unique @db.VarChar(16)
  channel         MarketingChannelType
  agentId         String?
  campaignLabel   String?               @db.VarChar(200)
  destination     String                @db.Text
  status          TrackingLinkStatus    @default(ACTIVE)
  // Aggregated counter — incremented on /s/:shortCode redirect.
  // We keep this denormalised so the index page can show click totals
  // without scanning the click table; `TrackingLinkClick` is the
  // source of truth for forensics.
  clickCount      Int                   @default(0)
  createdById     String
  createdAt       DateTime              @default(now())
  archivedAt      DateTime?

  createdBy       User                  @relation("TrackingLinkCreator", fields: [createdById], references: [id])
  agent           AffiliateAgent?       @relation(fields: [agentId], references: [id])
  clicks          TrackingLinkClick[]
  attributedLeads Lead[]                @relation("LeadAttributedLink")

  @@index([channel, createdAt])
  @@index([agentId, createdAt])
  @@index([status, createdAt])
  @@map("tracking_links")
}

model TrackingLinkClick {
  id              String                @id @default(uuid())
  linkId          String
  clickedAt       DateTime              @default(now())
  ipAddress       String?               @db.VarChar(64)
  userAgent       String?               @db.Text
  referer         String?               @db.Text

  link            TrackingLink          @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, clickedAt])
  @@map("tracking_link_clicks")
}

// ─── PR-SCORECARD-4 ─ Wix payment integration ────────────────────────────────

enum WixPaymentType {
  FREE_15MIN
  GAP_CLOSING
  LIA_CONSULTATION
  OTHER
}

enum WixPaymentStatus {
  RECEIVED
  REFUNDED
  DISPUTED
}

// One Wix payment / booking event. Created by the public webhook
// `POST /webhooks/wix/payment` (shared-secret authenticated).
// `wixPaymentId` is unique so retries from the Wix Automation are
// idempotent. `matchedLeadId` / `matchedUserId` are best-effort
// email matches captured at write time; the link is informational
// only — we do NOT auto-update lead status from this row (per
// strategic decision: payments are recorded, never actioned).
model WixPayment {
  id                String              @id @default(uuid())
  wixPaymentId      String              @unique @db.VarChar(200)
  wixBookingId      String?             @db.VarChar(200)
  paymentType       WixPaymentType
  amount            Decimal             @db.Decimal(10, 2)
  currency          String              @db.VarChar(3)
  status            WixPaymentStatus    @default(RECEIVED)
  customerEmail     String              @db.VarChar(200)
  customerName      String?             @db.VarChar(200)
  customerPhone     String?             @db.VarChar(64)
  bookingStart      DateTime?
  bookingEnd        DateTime?
  bookingLocation   String?             @db.VarChar(200)
  matchedLeadId     String?
  matchedUserId     String?
  rawPayload        Json
  receivedAt        DateTime            @default(now())

  matchedLead       Lead?               @relation("WixPaymentLead", fields: [matchedLeadId], references: [id])
  matchedUser       User?               @relation("WixPaymentUser", fields: [matchedUserId], references: [id])

  @@index([customerEmail, receivedAt])
  @@index([matchedLeadId])
  @@index([paymentType, receivedAt])
  @@index([status])
  @@map("wix_payments")
}

// ─── DOCUMENTS (R2-backed case attachments) ───────────────────────────
//
// Documents step 2 — sibling to the existing PR-LIA-5 review surface
// (AdmissionDocument / ApplicationDocument / VisaSupportingDocument +
// CaseDocumentReview), NOT a replacement. The bytes live in Cloudflare
// R2; this row holds the metadata + the opaque object key.
//
// Lifecycle: row is created PENDING when the backend issues a
// presigned upload URL; the browser flips it to UPLOADED on the
// confirm-upload callback, or to FAILED on abandon. The unique r2Key
// prevents two rows pointing at the same object.
//
// Enum name note: the obvious `DocumentStatus` was already taken by
// the legacy ApplicationDocument lifecycle (MISSING/UPLOADED/VERIFIED/
// REJECTED) at line ~277. Renamed here to `DocumentUploadStatus` so
// the two coexist without altering the legacy enum.

enum DocumentUploadStatus {
  PENDING
  UPLOADED
  FAILED
}

model Document {
  id           String               @id @default(cuid())
  caseId       String
  uploaderId   String
  r2Key        String               @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  status       DocumentUploadStatus @default(PENDING)
  category     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  case     Case @relation("CaseDocuments",   fields: [caseId],     references: [id], onDelete: Cascade)
  uploader User @relation("DocumentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@index([uploaderId])
  @@index([status])
  @@map("documents")
}
