// Phase 6.5 — finance staff verification state for each Payment row.
// Distinct from PaymentStatus (which tracks the Stripe/manual outcome):
// a payment can be Stripe-`succeeded` AND verification-`PENDING` until
// finance signs off. CONFIRMED = staff approved. REJECTED = staff
// flagged it (wrong amount, bad receipt, suspected duplicate).
enum PaymentVerificationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

