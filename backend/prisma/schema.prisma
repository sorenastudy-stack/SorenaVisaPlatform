// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model ApplicationDocument {
  id            String         @id @default(cuid())
  applicationId String
  type          String
  fileName      String?
  fileUrl       String?
  status        DocumentStatus @default(MISSING)
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
