generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  // Pre-existing values — kept verbatim to avoid breaking any row
  // already populated with them (per PR-CONSULT-1's "no auto-migration
  // of role values" rule). Existing staff users keep their current role.
  SUPER_ADMIN
  ADMIN
  SALES
  OPERATIONS
  LIA
  SUPPORT
  // PR-SCORECARD-1: leads who have submitted the Readiness
  // Assessment but haven't paid for an account yet. Sits between
  // "anonymous visitor" and "STUDENT" in the funnel.
  LEAD
  STUDENT
  AGENT
  // PR-CONSULT-1 additions for the staff-roles foundation.
  // OWNER is the only role that can approve owner-approval requests
  // (destructive / sensitive actions enqueued by SUPER_ADMIN).
  // CONSULTANT and FINANCE are new functional staff slots on VisaCase.
  OWNER
  CONSULTANT
  FINANCE
}

// PR-STAFF-RENAME — the staff-portal role taxonomy. "Staff" is the umbrella
// for everyone who logs into the staff portal; each has exactly one of these.
// ADVISER = LIA advisers only (no longer the umbrella). Distinct from the
// legacy `UserRole` (kept for auth guards + booking) and from the guard
// allow-list type `StaffAccessRole`.
enum StaffRole {
  ADMIN
  ADVISER
  SUPPORT_CONSULTANT
  ADMISSION_CONSULTANT
}

enum LeadStatus {
  NEW
  CONTACTED
  INTAKE_STARTED
  INTAKE_COMPLETED
  SCORING_DONE
  QUALIFIED
  NURTURE
  EXECUTING
  CLOSED_WON
  CLOSED_LOST
  DISQUALIFIED
}

enum ScoreBand {
  LOW
  MID
  HIGH
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

// PR-LIA-1: formal outcomes the LIA can record on a Case. Set on a
// LegalNote row when the LIA records a decision; null when the row
// is just a free-form note (or a system-generated audit-paired note).
enum LegalDecision {
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
  WITHDRAWN
}

// PR-LIA-4: direct messaging between the LIA and the client on a CRM
// Case. Two author roles only — system events go through AuditLog.
enum CaseMessageAuthorRole {
  LIA
  CLIENT
}

// PR-LIA-4: thread-row kind. MESSAGE is a free-form message either
// way. DOCUMENT_REQUEST is an LIA → client ask for a specific document
// (the client links one of their existing VisaSupportingDocument rows
// to fulfil it). PROGRESS_UPDATE is an LIA-authored status broadcast
// (rendered full-width on the client side).
enum CaseMessageKind {
  MESSAGE
  DOCUMENT_REQUEST
  PROGRESS_UPDATE
}

// PR-LIA-5: which source table a CaseDocumentReview points at. The
// review row lives in its own table — we never modify the source
// models. The original document is keyed by the matching (source,
// sourceRowId) pair. The user's spec named a fourth source
// (CASE_MESSAGE_FULFILMENT) which is really just a VisaSupportingDocument
// linked through a CaseMessage; the canonical row lives in
// visa_supporting_documents either way, so VISA_SUPPORTING covers it.
enum CaseDocumentReviewSource {
  ADMISSION
  APPLICATION
  VISA_SUPPORTING
}

// PR-LIA-5: the LIA's verdict on a single document. UNREVIEWED is
// the implicit default (no row exists); only APPROVED / REJECTED
// rows are stored. Re-reviewing upserts the existing row.
enum CaseDocumentReviewStatus {
  APPROVED
  REJECTED
}

enum RecommendedRoute {
  CONTENT_NURTURE
  WEBINAR
  ROADMAP
  ADMISSION_CONSULTATION
  SPECIALIST_CONSULTATION
  LIA_CONSULTATION
  EXECUTION_QUEUE
