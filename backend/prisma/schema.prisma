// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  // PR-DASH-1: structured event type that maps to a client-dashboard
  // activity-feed i18n key (STEP_STARTED / STEP_SAVED / DOCUMENT_RECORDED
  // / DOCUMENT_REMOVED / STATUS_CHANGED). Nullable on existing rows —
  // the dashboard read endpoint falls back to deriving the event type
  // from the `action` string for rows written before this PR. Future
  // mutation paths should populate this directly.
  eventType  String?
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // PR-CONSULT-4: actor name + role snapshot. Populated either at
  // write-time (new audit paths under this PR) or at delete-time
  // by the hard-delete service, so audit history attributes the
  // action correctly even after the actor row is gone. Older audit
  // rows leave both null; the summary helper falls back to
  // "(Removed user)" when the User join returns null AND the
  // snapshot is null.
  actorNameSnapshot String?
  actorRoleSnapshot String?

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  // Phase 8 — weekly client digest. The digest gather query filters
  // by `entityId = ? AND createdAt >= ? AND createdAt < ?` for Pass A
  // (case-scoped events keyed on caseId) and `entityId IN (small list)
  // AND createdAt range` for Pass B (PAYMENT / DOCUMENT / VisaMeeting /
  // VisaSupportTicket events). entityId is highly selective per row
  // (vs entityType which has a handful of distinct values), so a
  // composite leading with entityId lets Postgres do an index seek per
  // id then range-scan createdAt — much narrower than a type-led index.
  @@index([entityId, createdAt])
  @@map("audit_logs")
}

