# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sorena_visa"

# Security
HANDOFF_API_KEY="change-this-to-a-long-random-secure-string"

# Encryption (PII at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=<base64-32-bytes>
ENCRYPTION_KEY_VERSION=1
EMAIL_HASH_SECRET=<base64-32-bytes>

# App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# Email (SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="Sorena Visa <noreply@sorenavisa.co.nz>"

# Wix booking (PR-DASH-3)
# Public Wix booking calendar URL. Leave empty to disable the
# dashboard's "Book a meeting" button (it falls back to a disabled
# state with a contact-Sorena-directly message).
WIX_BOOKING_URL=""

# Anthropic Chatbot (PR-DASH-4)
# API key for the in-platform AI chatbot. If unset in development,
# chatbot endpoints return 503; in production the app fails to boot
# rather than silently serving 503s on a customer-facing feature.
ANTHROPIC_API_KEY=""
# Optional model override. Defaults to claude-haiku-4-5-20251001.
ANTHROPIC_CHATBOT_MODEL="claude-haiku-4-5-20251001"

# Wix lead-capture webhook (PR-WIX-1)
# Shared secret Wix sends in the `x-sorena-webhook-secret` header.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required for /api/webhooks/wix/lead-capture to accept requests —
# the guard fails closed when this is empty.
WIX_WEBHOOK_SECRET=""

# DocuSign Connect HMAC key (PR-DOCUSIGN-N)
# Verifies the X-DocuSign-Signature-* header (HMAC-SHA256 over the raw body)
# on POST /contracts/webhook. Generate in DocuSign Admin → Connect → Keys, and
# enable "Include HMAC Signature" on the Connect config. The webhook guard
# fails closed (401) when this is empty.
DOCUSIGN_CONNECT_HMAC_KEY=""
