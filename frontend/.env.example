NEXT_PUBLIC_API_URL=http://localhost:3001

# PR-DASH-3: Wix booking URL.
# Live value lives on the BACKEND (WIX_BOOKING_URL in backend/.env)
# and the frontend reads it via GET /api/student/booking-config so
# it stays off the static client bundle. This NEXT_PUBLIC_ placeholder
# is reserved for any future client-only fallback — leave empty.
NEXT_PUBLIC_WIX_BOOKING_URL=
